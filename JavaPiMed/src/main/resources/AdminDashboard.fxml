<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.AdminDashboardController"
            prefWidth="1650.0" prefHeight="960.0"
            stylesheets="@evenement-dashboard.css,@admin-dashboard.css"
            styleClass="root-pane">

    <left>
        <VBox prefWidth="250.0" minWidth="250.0" maxWidth="250.0" styleClass="sidebar">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="14.0" styleClass="logo-box">
                    <children>
                        <StackPane prefWidth="40.0" prefHeight="40.0">
                            <children>
                                <Label text="❤" styleClass="logo-heart"/>
                                <Label text="✚" styleClass="logo-plus"/>
                            </children>
                        </StackPane>
                        <Label text="MEDFLOW" styleClass="logo-text"/>
                    </children>
                </HBox>

                <Region prefHeight="1.0" maxHeight="1.0" styleClass="sidebar-separator"/>

                <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="sidebar-item">
                    <children>
                        <Label text="🩺" styleClass="sidebar-item-icon"/>
                        <Label text="Dashboard Admin" styleClass="sidebar-item-text"/>
                    </children>
                </HBox>

                <Label text="GESTIONS" styleClass="sidebar-section-title"/>

                <Button text=""
                        onAction="#toggleSubmenu"
                        alignment="CENTER_LEFT"
                        maxWidth="Infinity"
                        prefWidth="220.0"
                        contentDisplay="GRAPHIC_ONLY"
                        styleClass="sidebar-item, sidebar-btn">
                    <graphic>
                        <HBox alignment="CENTER_LEFT" spacing="10.0" maxWidth="Infinity">
                            <children>
                                <Label text="👤" styleClass="sidebar-item-icon"/>
                                <Label text="Utilisateurs" styleClass="sidebar-item-text"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label fx:id="userArrow" text="⌄" styleClass="sidebar-arrow"/>
                            </children>
                        </HBox>
                    </graphic>
                </Button>

                <VBox fx:id="submenuVBox"
                      spacing="18.0"
                      styleClass="submenu-card"
                      managed="false"
                      visible="false"
                      maxWidth="220.0">
                    <children>
                        <Label text="GESTION DES UTILISATEURS :" styleClass="submenu-title"/>
                        <Button fx:id="voirTousUsersBtn"
                                text="Voir tous les utilisateurs"
                                onAction="#onVoirTousUsers"
                                maxWidth="Infinity"
                                alignment="CENTER_LEFT"
                                styleClass="submenu-link"/>
                    </children>
                </VBox>

                <Region VBox.vgrow="ALWAYS"/>

                <Button onAction="#onLogout"
                        alignment="CENTER_LEFT"
                        maxWidth="Infinity"
                        styleClass="sidebar-item, sidebar-btn"
                        contentDisplay="GRAPHIC_ONLY">
                    <graphic>
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <children>
                                <Label text="↪" styleClass="sidebar-item-icon"/>
                                <Label text="Déconnexion" styleClass="sidebar-item-text"/>
                            </children>
                        </HBox>
                    </graphic>
                </Button>
            </children>
            <padding>
                <Insets top="24.0" right="18.0" bottom="24.0" left="18.0"/>
            </padding>
        </VBox>
    </left>

    <center>
        <VBox spacing="14.0" styleClass="main-area">
            <padding>
                <Insets top="16.0" right="18.0" bottom="18.0" left="18.0"/>
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="hero-card">
                <children>
                    <StackPane minWidth="88.0" minHeight="88.0" prefWidth="88.0" prefHeight="88.0" styleClass="hero-icon-box">
                        <children>
                            <Label text="👥" styleClass="hero-icon"/>
                        </children>
                    </StackPane>

                    <VBox spacing="8.0">
                        <children>
                            <Label text="Gestion des Utilisateurs" styleClass="hero-title"/>
                            <HBox spacing="14.0" alignment="CENTER_LEFT">
                                <children>
                                    <Label fx:id="inventoryCountLabel" text="0 utilisateur(s) dans votre espace" styleClass="hero-subtitle"/>
                                    <Label text="🛡 Admin" styleClass="admin-badge"/>
                                </children>
                            </HBox>
                        </children>
                    </VBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <HBox spacing="16.0" alignment="CENTER_RIGHT">
                        <children>
                            <Button text="📄 Rapport Audit PDF" onAction="#onExportSmartReport" styleClass="yellow-btn"/>
                            <Button text="⇢ Espace front" onAction="#onGoToFront" styleClass="white-btn"/>
                        </children>
                    </HBox>
                </children>
                <padding>
                    <Insets top="18.0" right="22.0" bottom="18.0" left="22.0"/>
                </padding>
            </HBox>

            <VBox spacing="12.0" styleClass="list-header-card admin-filter-card">
                <children>
                    <HBox alignment="CENTER_LEFT" spacing="12.0">
                        <children>
                            <Label text="🔎 Tri &amp; Recherche - Gestion Utilisateurs" styleClass="list-title"/>
                        </children>
                    </HBox>

                    <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="top-search-box">
                        <children>
                            <TextField fx:id="searchField"
                                       promptText="Recherche intelligente... ex: role:admin verified:yes name:ali"
                                       HBox.hgrow="ALWAYS"
                                       styleClass="top-search-input"/>
                            <ComboBox fx:id="sortCombo" prefWidth="210.0" styleClass="sort-combo"/>
                            <Button fx:id="sortDirectionBtn" text="↓ Desc" onAction="#toggleSortDirection" styleClass="white-btn"/>
                            <Label text="🔔" styleClass="notif-icon"/>
                        </children>
                    </HBox>

                    <Label fx:id="reportHintLabel"
                           text="Astuce recherche: role:admin  verified:yes/no  status:active  name:ahmed"
                           styleClass="pill-label"/>
                </children>
                <padding>
                    <Insets top="14.0" right="18.0" bottom="14.0" left="18.0"/>
                </padding>
            </VBox>

            <HBox spacing="12.0">
                <children>
                    <VBox spacing="8.0" styleClass="stat-card, compact-stat-card" HBox.hgrow="ALWAYS">
                        <children>
                            <StackPane prefWidth="46.0" prefHeight="46.0" styleClass="stat-badge blue-badge">
                                <children>
                                    <Label text="👥" styleClass="stat-emoji"/>
                                </children>
                            </StackPane>
                            <Label fx:id="totalUsersLabel" text="0" styleClass="stat-number"/>
                            <Label text="Total Utilisateurs" styleClass="stat-text"/>
                        </children>
                    </VBox>

                    <VBox spacing="8.0" styleClass="stat-card, compact-stat-card" HBox.hgrow="ALWAYS">
                        <children>
                            <StackPane prefWidth="46.0" prefHeight="46.0" styleClass="stat-badge green-badge">
                                <children>
                                    <Label text="🛡" styleClass="stat-emoji"/>
                                </children>
                            </StackPane>
                            <Label fx:id="adminUsersLabel" text="0" styleClass="stat-number"/>
                            <Label text="Admins" styleClass="stat-text"/>
                        </children>
                    </VBox>

                    <VBox spacing="8.0" styleClass="stat-card, compact-stat-card" HBox.hgrow="ALWAYS">
                        <children>
                            <StackPane prefWidth="46.0" prefHeight="46.0" styleClass="stat-badge orange-badge">
                                <children>
                                    <Label text="🧑‍⚕" styleClass="stat-emoji"/>
                                </children>
                            </StackPane>
                            <Label fx:id="staffUsersLabel" text="0" styleClass="stat-number"/>
                            <Label text="Staff" styleClass="stat-text"/>
                        </children>
                    </VBox>

                    <VBox spacing="8.0" styleClass="stat-card, compact-stat-card" HBox.hgrow="ALWAYS">
                        <children>
                            <StackPane prefWidth="46.0" prefHeight="46.0" styleClass="stat-badge red-badge">
                                <children>
                                    <Label text="🧑" styleClass="stat-emoji"/>
                                </children>
                            </StackPane>
                            <Label fx:id="patientUsersLabel" text="0" styleClass="stat-number"/>
                            <Label text="Patients" styleClass="stat-text"/>
                        </children>
                    </VBox>
                </children>
            </HBox>

            <VBox styleClass="table-wrapper" VBox.vgrow="ALWAYS">
                <children>
                    <TableView fx:id="userTable" VBox.vgrow="ALWAYS" styleClass="events-table">
                        <columns>
                            <TableColumn fx:id="idCol" prefWidth="70.0" text="ID"/>
                            <TableColumn fx:id="cinCol" prefWidth="120.0" text="CIN"/>
                            <TableColumn fx:id="nomCol" prefWidth="130.0" text="NOM"/>
                            <TableColumn fx:id="prenomCol" prefWidth="130.0" text="PRÉNOM"/>
                            <TableColumn fx:id="emailCol" prefWidth="250.0" text="EMAIL"/>
                            <TableColumn fx:id="phoneCol" prefWidth="150.0" text="TÉLÉPHONE"/>
                            <TableColumn fx:id="roleCol" prefWidth="110.0" text="RÔLE"/>
                            <TableColumn fx:id="statutCol" prefWidth="130.0" text="STATUT"/>
                            <TableColumn fx:id="verifiedCol" prefWidth="110.0" text="VÉRIFIÉ"/>
                            <TableColumn fx:id="actionsCol" prefWidth="150.0" text="ACTIONS"/>
                        </columns>
                    </TableView>
                </children>
            </VBox>
        </VBox>
    </center>
</BorderPane>
