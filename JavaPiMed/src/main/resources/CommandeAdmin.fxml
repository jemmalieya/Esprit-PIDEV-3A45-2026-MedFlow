<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="rootPane"
            prefWidth="1500.0"
            prefHeight="880.0"
            styleClass="app-root"
            stylesheets="@CSS/admin-commandes.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.AdminCommandeController">

    <left>
        <BorderPane prefWidth="320.0" styleClass="sidebar">

            <top>
                <VBox spacing="8">
                    <padding>
                        <Insets top="26" right="20" bottom="16" left="20"/>
                    </padding>

                    <Label text="MedFlow Admin" styleClass="brand-title"/>
                    <Label text="ESPACE ADMINISTRATION" styleClass="brand-subtitle"/>
                    <Separator styleClass="side-separator"/>
                </VBox>
            </top>

            <center>
                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" styleClass="sidebar-scroll">
                    <content>
                        <VBox spacing="10">
                            <padding>
                                <Insets top="4" right="18" bottom="16" left="18"/>
                            </padding>

                            <Button text="Accueil Admin" onAction="#openDashboard" styleClass="nav-button"/>

                            <TitledPane text="Utilisateurs" expanded="false" styleClass="sidebar-dropdown">
                                <content>
                                    <VBox spacing="6" styleClass="dropdown-content">
                                        <Button text="Patients" onAction="#openPatients" styleClass="sub-nav-button"/>
                                        <Button text="Tous les utilisateurs" onAction="#openUsers" styleClass="sub-nav-button"/>
                                        <Button text="Demandes de rôle" onAction="#openRoles" styleClass="sub-nav-button"/>
                                    </VBox>
                                </content>
                            </TitledPane>

                            <TitledPane text="Produits" expanded="true" styleClass="sidebar-dropdown">
                                <content>
                                    <VBox spacing="6" styleClass="dropdown-content">
                                        <Button text="Liste des produits" onAction="#openProduits" styleClass="sub-nav-button"/>
                                        <Button text="Commandes" onAction="#openCommandes" styleClass="sub-nav-button-active"/>
                                        <Button text="Détection Épidémie" onAction="#openDetection" styleClass="sub-nav-button"/>
                                        <Button text="Statistiques produits" onAction="#openStatsProduits" styleClass="sub-nav-button"/>
                                    </VBox>
                                </content>
                            </TitledPane>

                            <TitledPane text="Événements" expanded="false" styleClass="sidebar-dropdown">
                                <content>
                                    <VBox spacing="6" styleClass="dropdown-content">
                                        <Button text="Liste des événements" onAction="#openEvents" styleClass="sub-nav-button"/>
                                        <Button text="Participants demandes" onAction="#openEventParticipants" styleClass="sub-nav-button"/>
                                        <Button text="Ressources" onAction="#openRessources" styleClass="sub-nav-button"/>
                                        <Button text="Stats événements" onAction="#openStatsEvents" styleClass="sub-nav-button"/>
                                    </VBox>
                                </content>
                            </TitledPane>

                            <TitledPane text="Consultations" expanded="false" styleClass="sidebar-dropdown">
                                <content>
                                    <VBox spacing="6" styleClass="dropdown-content">
                                        <Button text="Consultations par Docteur" onAction="#openConsultations" styleClass="sub-nav-button"/>
                                        <Button text="Statistiques consultations" onAction="#openStatsConsultations" styleClass="sub-nav-button"/>
                                    </VBox>
                                </content>
                            </TitledPane>

                            <TitledPane text="Réclamations" expanded="false" styleClass="sidebar-dropdown">
                                <content>
                                    <VBox spacing="6" styleClass="dropdown-content">
                                        <Button text="Liste des réclamations" onAction="#openReclamations" styleClass="sub-nav-button"/>
                                        <Button text="Statistiques réclamations" onAction="#openStatsReclamations" styleClass="sub-nav-button"/>
                                    </VBox>
                                </content>
                            </TitledPane>

                            <TitledPane text="Blog et Posts" expanded="false" styleClass="sidebar-dropdown">
                                <content>
                                    <VBox spacing="6" styleClass="dropdown-content">
                                        <Button text="Liste des posts" onAction="#openPosts" styleClass="sub-nav-button"/>
                                        <Button text="Commentaires" onAction="#openBlogComments" styleClass="sub-nav-button"/>
                                        <Button text="Modération blog" onAction="#openBlogModeration" styleClass="sub-nav-button"/>
                                    </VBox>
                                </content>
                            </TitledPane>

                            <Button text="Déconnexion" onAction="#logout" styleClass="logout-button"/>
                        </VBox>
                    </content>
                </ScrollPane>
            </center>

            <bottom>
                <VBox spacing="10">
                    <padding>
                        <Insets top="12" right="18" bottom="22" left="18"/>
                    </padding>

                    <Separator styleClass="side-separator"/>
                    <Button text="Retour Site" onAction="#goBackSite" styleClass="back-site-button"/>
                </VBox>
            </bottom>

        </BorderPane>
    </left>

    <top>
        <HBox alignment="CENTER_LEFT" spacing="18" styleClass="top-bar">
            <padding>
                <Insets top="18" right="28" bottom="18" left="28"/>
            </padding>

            <Button text="Menu" styleClass="menu-button"/>

            <VBox spacing="3">
                <Label text="Gestion des Commandes" styleClass="page-title"/>
                <Label fx:id="dateLabel" text="Admin • Commandes" styleClass="page-subtitle"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <TextField fx:id="topSearchField" promptText="Rechercher..." styleClass="search-field"/>
            <Button text="Notif" styleClass="icon-button"/>
            <Button text="Param" styleClass="icon-button"/>
            <Label text="A" styleClass="avatar-label"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="content-scroll">
            <content>
                <VBox spacing="22" styleClass="page-content">
                    <padding>
                        <Insets top="24" right="24" bottom="36" left="24"/>
                    </padding>

                    <HBox alignment="CENTER_LEFT" spacing="10" styleClass="commande-breadcrumb">
                        <Label text="Gestion des Commandes" styleClass="commande-breadcrumb-title"/>
                        <Label text="|" styleClass="commande-breadcrumb-sep"/>
                        <Label text="Admin" styleClass="commande-breadcrumb-active"/>
                        <Label text="›" styleClass="commande-breadcrumb-sep"/>
                        <Label text="Commandes" styleClass="commande-breadcrumb-muted"/>
                    </HBox>

                    <HBox spacing="12" alignment="CENTER_LEFT" styleClass="commande-kpi-row">

                        <VBox styleClass="cmd-stat-total">
                            <Label text="Total" styleClass="cmd-stat-title"/>
                            <Label fx:id="totalCommandesValueLabel" text="0" styleClass="cmd-stat-value"/>
                            <Label text="Commandes" styleClass="cmd-stat-subtitle"/>
                        </VBox>

                        <VBox styleClass="cmd-stat-attente">
                            <Label text="En Attente" styleClass="cmd-stat-title"/>
                            <Label fx:id="attenteLabel" text="0" styleClass="cmd-stat-value"/>
                            <Label text="À vérifier" styleClass="cmd-stat-subtitle"/>
                        </VBox>

                        <VBox styleClass="cmd-stat-cours">
                            <Label text="En Cours" styleClass="cmd-stat-title"/>
                            <Label fx:id="coursLabel" text="0" styleClass="cmd-stat-value"/>
                            <Label text="Traitement" styleClass="cmd-stat-subtitle"/>
                        </VBox>

                        <VBox styleClass="cmd-stat-livraison">
                            <Label text="Livraison" styleClass="cmd-stat-title"/>
                            <Label fx:id="livraisonLabel" text="0" styleClass="cmd-stat-value"/>
                            <Label text="En route" styleClass="cmd-stat-subtitle"/>
                        </VBox>

                        <VBox styleClass="cmd-stat-livree">
                            <Label text="Livrées" styleClass="cmd-stat-title"/>
                            <Label fx:id="livreesLabel" text="0" styleClass="cmd-stat-value"/>
                            <Label text="Terminées" styleClass="cmd-stat-subtitle"/>
                        </VBox>

                        <VBox styleClass="cmd-stat-annulee">
                            <Label text="Annulées" styleClass="cmd-stat-title"/>
                            <Label fx:id="annuleesLabel" text="0" styleClass="cmd-stat-value"/>
                            <Label text="Refusées" styleClass="cmd-stat-subtitle"/>
                        </VBox>

                    </HBox>

                    <HBox spacing="18" styleClass="money-row">
                        <VBox styleClass="money-purple-card" HBox.hgrow="ALWAYS">
                            <Label text="Chiffre d’Affaires Total" styleClass="money-title"/>
                            <Label fx:id="caTotalLabel" text="0,00 DT" styleClass="money-value"/>
                            <Label text="Toutes les commandes payées" styleClass="money-subtitle"/>
                        </VBox>

                        <VBox styleClass="money-pink-card" HBox.hgrow="ALWAYS">
                            <Label text="CA ce Mois" styleClass="money-title"/>
                            <Label fx:id="caMoisLabel" text="0,00 DT" styleClass="money-value"/>
                            <Label text="Mois courant" styleClass="money-subtitle"/>
                        </VBox>
                    </HBox>

                    <HBox alignment="CENTER_LEFT" spacing="14" styleClass="filter-card">
                        <TextField fx:id="searchCommandeField" promptText="Rechercher une commande, un client, un statut..." styleClass="filter-input"/>
                        <ComboBox fx:id="filtreStatutCombo" promptText="Filtrer statut..." styleClass="filter-combo"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="resultCountLabel" text="0 commande(s)" styleClass="result-label"/>
                    </HBox>

                    <VBox spacing="0" styleClass="table-card">

                        <HBox alignment="CENTER_LEFT" styleClass="table-title-row">
                            <Label text="Liste Complète des Commandes" styleClass="table-title"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label text="Cliquez sur Voir pour les détails" styleClass="table-help"/>
                        </HBox>

                        <HBox alignment="CENTER_LEFT" styleClass="table-header">
                            <Label text="#ID" prefWidth="64" styleClass="header-cell"/>
                            <Label text="CLIENT" prefWidth="260" styleClass="header-cell"/>
                            <Label text="DATE" prefWidth="125" styleClass="header-cell"/>
                            <Label text="MONTANT" prefWidth="112" styleClass="header-cell"/>
                            <Label text="STATUT" prefWidth="125" styleClass="header-cell"/>
                            <Label text="PAIEMENT" prefWidth="120" styleClass="header-cell"/>
                            <Label text="DÉTAILS" prefWidth="78" styleClass="header-cell"/>
                        </HBox>

                        <VBox fx:id="commandesRowsContainer" spacing="0"/>

                    </VBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>