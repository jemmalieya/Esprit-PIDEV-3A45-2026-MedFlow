<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.EvenementController"
            prefWidth="1650.0"
            prefHeight="960.0"
            styleClass="root-layout"
            stylesheets="@CSS/style-ajout-evenement.css">

    <left>
        <VBox prefWidth="250.0" minWidth="250.0" maxWidth="250.0" styleClass="sidebar">
            <padding>
                <Insets top="24.0" right="18.0" bottom="24.0" left="18.0"/>
            </padding>

            <children>
                <HBox alignment="CENTER_LEFT" spacing="14.0" styleClass="logo-box">
                    <children>
                        <StackPane prefWidth="40.0" prefHeight="40.0">
                            <children>
                                <Label text="❤" styleClass="logo-heart"/>
                                <Label text="✚" styleClass="logo-plus"/>
                            </children>
                        </StackPane>
                        <Label text="MEDFLOW" styleClass="logo-text"/>
                    </children>
                </HBox>

                <Region prefHeight="1.0" styleClass="sidebar-separator"/>

                <Label text="GESTIONS" styleClass="sidebar-section-title"/>

                <Button fx:id="evenementBtn"
                        onAction="#toggleSubmenu"
                        maxWidth="Infinity"
                        contentDisplay="GRAPHIC_ONLY"
                        styleClass="sidebar-item, sidebar-btn, active-product-btn">
                    <graphic>
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <children>
                                <Label text="📅" styleClass="sidebar-item-icon"/>
                                <Label text="Événements" styleClass="sidebar-item-text"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label fx:id="evenementArrow" text="⌃" styleClass="sidebar-arrow"/>
                            </children>
                        </HBox>
                    </graphic>
                </Button>

                <VBox fx:id="submenuVBox"
                      spacing="18"
                      styleClass="submenu-card"
                      managed="false"
                      visible="false">
                    <children>
                        <Label text="GESTION DES ÉVÉNEMENTS :" styleClass="submenu-title"/>

                        <Button text="Voir tous les événements"
                                onAction="#retourListeEvenements"
                                maxWidth="Infinity"
                                styleClass="submenu-link"/>
                    </children>
                </VBox>

                <Region VBox.vgrow="ALWAYS"/>

                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="sidebar-logout">
                    <children>
                        <Label text="↪" styleClass="sidebar-item-icon"/>
                        <Label text="Déconnexion" styleClass="sidebar-item-text"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true" pannable="true" styleClass="main-scroll">
            <content>
                <VBox spacing="22" styleClass="page-container">
                    <padding>
                        <Insets top="22" right="28" bottom="28" left="28"/>
                    </padding>

                    <children>
                        <HBox alignment="CENTER_LEFT">
                            <children>
                                <VBox spacing="6">
                                    <children>
                                        <Label text="Événements en cards" styleClass="page-title"/>
                                        <Label text="Vue back-office des événements"
                                               styleClass="page-subtitle"/>
                                    </children>
                                </VBox>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button text="← Retour"
                                        onAction="#retourListeEvenements"
                                        styleClass="btn-retour"/>
                            </children>
                        </HBox>

                        <FlowPane fx:id="cardsContainer"
                                  hgap="20"
                                  vgap="20"
                                  prefWrapLength="1200"/>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>
