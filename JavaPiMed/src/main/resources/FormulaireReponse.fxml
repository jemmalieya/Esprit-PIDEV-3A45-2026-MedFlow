<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.ReponseFormController"
            prefWidth="1650.0" prefHeight="960.0"
            styleClass="root-pane">

    <left>
        <VBox prefWidth="250.0" minWidth="250.0" maxWidth="250.0" styleClass="sidebar">
            <children>

                <HBox alignment="CENTER_LEFT" spacing="14.0" styleClass="logo-box">
                    <children>
                        <StackPane prefWidth="40.0" prefHeight="40.0">
                            <children>
                                <Label text="❤" styleClass="logo-heart"/>
                                <Label text="✚" styleClass="logo-plus"/>
                            </children>
                        </StackPane>
                        <Label text="MEDFLOW" styleClass="logo-text"/>
                    </children>
                </HBox>

                <Region prefHeight="1.0" maxHeight="1.0" styleClass="sidebar-separator"/>

                <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="sidebar-item">
                    <children>
                        <Label text="🩺" styleClass="sidebar-item-icon"/>
                        <Label text="Dashboard" styleClass="sidebar-item-text"/>
                    </children>
                </HBox>

                <Label text="GESTIONS" styleClass="sidebar-section-title"/>

                <Button fx:id="evenementBtn"
                        text=""
                        onAction="#toggleSubmenu"
                        alignment="CENTER_LEFT"
                        maxWidth="Infinity"
                        prefWidth="220.0"
                        contentDisplay="GRAPHIC_ONLY"
                        styleClass="sidebar-item, sidebar-btn">

                    <graphic>
                        <HBox alignment="CENTER_LEFT" spacing="10.0" maxWidth="Infinity">
                            <children>
                                <Label text="📅" styleClass="sidebar-item-icon"/>
                                <Label text="Événements" styleClass="sidebar-item-text"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label fx:id="evenementArrow" text="⌄" styleClass="sidebar-arrow"/>
                            </children>
                        </HBox>
                    </graphic>
                </Button>

                <VBox fx:id="submenuVBox"
                      spacing="18.0"
                      styleClass="submenu-card"
                      managed="false"
                      visible="false"
                      maxWidth="220.0">
                    <children>
                        <Label text="GESTION DES ÉVÉNEMENTS :" styleClass="submenu-title"/>

                        <Button text="Voir tous les événements"
                                onAction="#onVoirTousEvenements"
                                maxWidth="Infinity"
                                alignment="CENTER_LEFT"
                                styleClass="submenu-link"/>

                        <Button text="↗ Tableau de bord Admin BI"
                                onAction="#onTableauBordAdmin"
                                maxWidth="Infinity"
                                alignment="CENTER_LEFT"
                                styleClass="submenu-link"/>

                        <Button text="Autres actions"
                                onAction="#onAutresActions"
                                maxWidth="Infinity"
                                alignment="CENTER_LEFT"
                                styleClass="submenu-link"/>
                    </children>
                </VBox>

                <Region VBox.vgrow="ALWAYS"/>

                <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="sidebar-item">
                    <children>
                        <Label text="↪" styleClass="sidebar-item-icon"/>
                        <Label text="Déconnexion" styleClass="sidebar-item-text"/>
                    </children>
                </HBox>

            </children>
            <padding>
                <Insets top="24.0" right="18.0" bottom="24.0" left="18.0"/>
            </padding>
        </VBox>
    </left>

    <center>
        <VBox spacing="22.0" styleClass="main-area">
            <padding>
                <Insets top="18.0" right="22.0" bottom="22.0" left="22.0"/>
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="14.0" styleClass="top-search-box">
                <children>
                    <TextField promptText="" HBox.hgrow="ALWAYS" styleClass="top-search-input"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="🔔" styleClass="notif-icon"/>
                </children>
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="hero-card">
                <children>
                    <StackPane minWidth="88.0" minHeight="88.0" prefWidth="88.0" prefHeight="88.0" styleClass="hero-icon-box">
                        <children>
                            <Label text="💬" styleClass="hero-icon"/>
                        </children>
                    </StackPane>

                    <VBox spacing="10.0">
                        <children>
                            <Label text="Formulaire de Réponse" styleClass="hero-title"/>
                            <HBox spacing="14.0" alignment="CENTER_LEFT">
                                <children>
                                    <Label fx:id="reclamationLabel" text="Réclamation: REF-001" styleClass="hero-subtitle"/>
                                    <Label text="🛡 Admin" styleClass="admin-badge"/>
                                </children>
                            </HBox>
                        </children>
                    </VBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <HBox spacing="16.0" alignment="CENTER_RIGHT">
                        <children>
                            <Button text="⬅ Retour" onAction="#onRetour" styleClass="white-btn"/>
                        </children>
                    </HBox>
                </children>
                <padding>
                    <Insets top="30.0" right="30.0" bottom="30.0" left="30.0"/>
                </padding>
            </HBox>

            <VBox spacing="20.0" styleClass="form-card" VBox.vgrow="ALWAYS">
                <padding>
                    <Insets top="30.0" right="30.0" bottom="30.0" left="30.0"/>
                </padding>

                <Label text="Détails de la Réclamation" styleClass="form-section-title"/>
                <VBox spacing="10.0">
                    <children>
                        <Label fx:id="contenuLabel" text="Contenu: ..." styleClass="form-label"/>
                        <Label fx:id="descriptionLabel" text="Description: ..." styleClass="form-label"/>
                        <Label fx:id="typeLabel" text="Type: ..." styleClass="form-label"/>
                        <Label fx:id="statutLabel" text="Statut: ..." styleClass="form-label"/>
                    </children>
                </VBox>

                <Region prefHeight="20.0"/>

                <Label text="Votre Réponse" styleClass="form-section-title"/>
                <VBox spacing="15.0">
                    <children>
                        <VBox spacing="5.0">
                            <Label text="Type de Réponse" styleClass="form-label"/>
                            <ComboBox fx:id="typeReponseCombo" promptText="Sélectionner le type" styleClass="form-combo">
                                <items>
                                    <fx:reference source="types"/>
                                </items>
                            </ComboBox>
                        </VBox>

                        <VBox spacing="5.0">
                            <Label text="Message" styleClass="form-label"/>
                            <TextArea fx:id="messageArea" promptText="Saisir votre réponse..." styleClass="form-textarea" prefRowCount="8"/>
                        </VBox>

                        <HBox spacing="16.0" alignment="CENTER_RIGHT">
                            <Button text="Annuler" onAction="#onAnnuler" styleClass="cancel-btn"/>
                            <Button text="Envoyer" onAction="#onEnvoyer" styleClass="submit-btn"/>
                        </HBox>
                    </children>
                </VBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>
