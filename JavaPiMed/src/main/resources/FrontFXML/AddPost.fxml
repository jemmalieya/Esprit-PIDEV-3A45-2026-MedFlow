<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Tooltip?>

<?import javafx.scene.layout.FlowPane?>
<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/21"
            fx:controller="tn.esprit.controllers.AddPostController"
            prefWidth="1400.0"
            prefHeight="820.0"
            stylesheets="@../CSS/booking.css,@../CSS/add-post.css"
            styleClass="root-pane">

    <left>
        <fx:include source="Sidebar.fxml"/>
    </left>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" styleClass="main-scroll">
            <content>
                <VBox spacing="24" styleClass="main-area">
                    <padding>
                        <Insets top="26" right="28" bottom="26" left="28"/>
                    </padding>

                    <!-- Header -->
                    <HBox alignment="CENTER_LEFT" spacing="16" styleClass="page-header">
                        <VBox spacing="4">
                            <Label fx:id="formTitle" text="Nouveau Post" styleClass="page-title"/>
                            <Label text="Créez un post avec aperçu instantané à droite."
                                   styleClass="page-subtitle"/>
                        </VBox>

                        <Region HBox.hgrow="ALWAYS"/>

                        <Button text="← Retour"
                                onAction="#goBackToBlog"
                                styleClass="back-btn"/>
                    </HBox>

                    <!-- Main content -->
                    <HBox spacing="24" alignment="TOP_LEFT">
                        <!-- Form -->
                        <VBox spacing="18" styleClass="form-card" HBox.hgrow="ALWAYS">
                            <Label text="Informations du post" styleClass="section-title"/>

                            <GridPane hgap="16" vgap="16">
                                <columnConstraints>
                                </columnConstraints>

                                <!-- TITRE -->
                                <Label text="Titre" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                <TextField fx:id="titreField"
                                           promptText="Entrez un titre"
                                           GridPane.columnIndex="0"
                                           GridPane.rowIndex="1"/>
                                <Label fx:id="titreError"
                                       style="-fx-text-fill: red;"
                                       GridPane.columnIndex="0"
                                       GridPane.rowIndex="2"/>

                                <!-- CATEGORIE -->
                                <Label text="Catégorie" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                                <ComboBox fx:id="categorieBox"
                                          GridPane.columnIndex="1"
                                          GridPane.rowIndex="1"/>

                                <!-- LOCALISATION -->
                                <Label text="Localisation" GridPane.columnIndex="0" GridPane.rowIndex="3"/>

                                <HBox spacing="8"
                                      alignment="CENTER_LEFT"
                                      GridPane.columnIndex="0"
                                      GridPane.rowIndex="4">

                                    <TextField fx:id="localisationField"
                                               promptText="Ex: Tunis"
                                               HBox.hgrow="ALWAYS"/>

                                    <Button text="🗺"
                                            onAction="#handleOpenMapPicker"
                                            styleClass="map-small-btn">
                                        <tooltip>
                                            <Tooltip text="Choisir sur la carte"/>
                                        </tooltip>
                                    </Button>

                                    <Button text="📍"
                                            onAction="#handleUseCurrentLocation"
                                            styleClass="location-small-btn">
                                        <tooltip>
                                            <Tooltip text="Ma position actuelle"/>
                                        </tooltip>
                                    </Button>
                                </HBox>

                                <Label fx:id="localisationError"
                                       style="-fx-text-fill: red;"
                                       GridPane.columnIndex="0"
                                       GridPane.rowIndex="5"/>

                                <!-- HUMEUR -->
                                <Label text="Humeur" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                                <ComboBox fx:id="humeurBox"
                                          GridPane.columnIndex="1"
                                          GridPane.rowIndex="4"/>

                                <!-- IMAGE -->
                                <Label text="Image web à envoyer vers Cloudinary"
                                       GridPane.columnIndex="0"
                                       GridPane.rowIndex="6"/>

                                <TextField fx:id="imageField"
                                           promptText="Collez une URL image : https://..."
                                           GridPane.columnIndex="0"
                                           GridPane.rowIndex="7"/>

                                <Label fx:id="imageError"
                                       style="-fx-text-fill: red;"
                                       GridPane.columnIndex="0"
                                       GridPane.rowIndex="8"/>

                                <!-- HASHTAGS -->
                                <Label text="Hashtags" GridPane.columnIndex="1" GridPane.rowIndex="6"/>
                                <TextField fx:id="hashtagsField"
                                           promptText="#urgence #hopital"
                                           GridPane.columnIndex="1"
                                           GridPane.rowIndex="7"/>
                                <Label fx:id="hashtagsError"
                                       style="-fx-text-fill: red;"
                                       GridPane.columnIndex="1"
                                       GridPane.rowIndex="8"/>


                                <!-- CONTENU -->
                                <!-- CONTENU -->
                                <HBox alignment="CENTER_LEFT"
                                      spacing="10"
                                      GridPane.columnIndex="0"
                                      GridPane.rowIndex="9"
                                      GridPane.columnSpan="2">

                                    <Label text="Contenu"/>

                                    <Region HBox.hgrow="ALWAYS"/>

                                    <Button text="📚 Références"
                                            onAction="#handleFindScientificReferences"
                                            style="-fx-background-color: #0f766e;
                   -fx-text-fill: white;
                   -fx-font-weight: bold;
                   -fx-background-radius: 12;
                   -fx-padding: 9 14;
                   -fx-cursor: hand;">
                                        <tooltip>
                                            <Tooltip text="Trouver des références scientifiques avec OpenAlex"/>
                                        </tooltip>
                                    </Button>

                                    <Button text="✨ Améliorer avec IA"
                                            onAction="#handleImproveWithAi"
                                            styleClass="ai-assistant-btn"/>
                                </HBox>

                                <TextArea fx:id="contenuArea"
                                          prefRowCount="8"
                                          promptText="Écrivez le contenu du post..."
                                          GridPane.columnIndex="0"
                                          GridPane.rowIndex="10"
                                          GridPane.columnSpan="2"/>


                                <Label fx:id="contenuError"
                                       style="-fx-text-fill: red;"
                                       GridPane.columnIndex="0"
                                       GridPane.rowIndex="11"
                                       GridPane.columnSpan="2"/>

                                <CheckBox fx:id="anonymeCheck"
                                          text="Publier en anonyme"
                                          GridPane.columnIndex="0"
                                          GridPane.rowIndex="12"
                                          GridPane.columnSpan="2"/>
                            </GridPane>

                            <HBox alignment="CENTER_RIGHT" spacing="12">
                                <Button text="Annuler" onAction="#goBackToBlog" styleClass="cancel-btn"/>
                                <Button fx:id="publishButton" text="Publier" onAction="#handlePublish" styleClass="publish-btn"/>
                            </HBox>
                        </VBox>

                        <!-- Preview -->
                        <VBox spacing="18" styleClass="preview-column" prefWidth="360" minWidth="360" maxWidth="360">
                            <Label text="Aperçu" styleClass="section-title"/>

                            <VBox styleClass="preview-card" spacing="12">
                                <ImageView fx:id="previewImage"
                                           fitWidth="320"
                                           fitHeight="190"
                                           preserveRatio="false"
                                           smooth="true"/>

                                <Label fx:id="previewCategory" text="Catégorie" styleClass="preview-badge"/>
                                <Label fx:id="previewTitle" text="Titre du post" styleClass="preview-title" wrapText="true"/>
                                <Label fx:id="previewContent" text="Le contenu du post apparaîtra ici..." styleClass="preview-content" wrapText="true"/>
                                <Label fx:id="previewMeta" text="Aujourd’hui · Tunis · MedFlow Admin" styleClass="preview-meta" wrapText="true"/>

                                <FlowPane fx:id="previewTagsPane" hgap="8" vgap="8"/>
                            </VBox>

                            <VBox styleClass="tip-card" spacing="8">
                                <Label text="Conseil" styleClass="tip-title"/>
                                <Label text="Un titre court et une image claire donnent un meilleur rendu dans la liste des posts."
                                       wrapText="true"
                                       styleClass="tip-text"/>
                            </VBox>
                        </VBox>
                    </HBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>