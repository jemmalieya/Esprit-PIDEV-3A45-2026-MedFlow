<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.ScrollPane?>

<!-- Just the center content - no BorderPane, no Sidebar include, no controller -->
<ScrollPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/21"
            pannable="true"
            hbarPolicy="NEVER"
            vbarPolicy="AS_NEEDED"
            styleClass="main-scroll"
            fx:controller="tn.esprit.controllers.ConsultationController">

            <content>
                <VBox spacing="24" styleClass="main-area">
                    <padding>
                        <Insets top="26" right="28" bottom="26" left="28"/>
                    </padding>

                    <!-- HEADER -->
                    <VBox spacing="6" styleClass="page-header">
                        <Label text="Booking Appointments" styleClass="page-title"/>
                        <Label text="Choose the date, the booking mode and the reason. Confirm your appointment in a clean and modern workflow."
                               wrapText="true"
                               styleClass="page-subtitle"/>
                    </VBox>

                    <!-- PAGE NAVIGATION BUTTONS -->
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <Button text="📅 Booking" styleClass="page-nav-button-active" onAction="#handleShowBookingPage" fx:id="bookingPageBtn"/>
                        <Button text="📋 My Bookings" styleClass="page-nav-button" onAction="#handleShowMyBookingsPage" fx:id="myBookingsPageBtn"/>
                        <Button text="📋 My Medical Records n Reports" styleClass="page-nav-button" onAction="#handleShowMyRecords" fx:id="myRecordsPageBtn"/>
                    </HBox>

                    <!-- PAGES CONTAINER (StackPane to switch between pages) -->
                    <StackPane VBox.vgrow="ALWAYS" styleClass="pages-container">
                        <!-- PAGE 1: BOOKING -->
                        <VBox spacing="24" styleClass="page-content" fx:id="bookingPage">
                            <!-- BIG BOOKING CARD -->
                            <HBox spacing="22">
                                <!-- LEFT CARD -->
                                <VBox spacing="18" HBox.hgrow="ALWAYS" styleClass="booking-card">
                            <Label text="Select appointment date" styleClass="card-title"/>

                            <StackPane styleClass="calendar-box">
                                <VBox spacing="10" prefHeight="300">
                                    <!-- Week Navigation -->
                                    <HBox spacing="16" alignment="CENTER">
                                        <Button text="←" styleClass="calendar-nav-button" onAction="#handlePreviousWeek"/>
                                        <Label fx:id="monthYearLabel" text="07 Apr 2026 - 11 Apr 2026" styleClass="calendar-month-label"/>
                                        <Button text="→" styleClass="calendar-nav-button" onAction="#handleNextWeek"/>
                                    </HBox>

                                    <!-- Weekly Workweek Calendar -->
                                    <ScrollPane hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" fitToHeight="true" pannable="true" styleClass="calendar-schedule-scroll" VBox.vgrow="ALWAYS">
                                        <content>
                                            <VBox spacing="8" styleClass="calendar-grid-container">
                                                <HBox fx:id="calendarHeaderRow" spacing="6"/>
                                                <VBox fx:id="timeSlotGrid" spacing="6" styleClass="time-slots-container"/>
                                            </VBox>
                                        </content>
                                    </ScrollPane>
                                </VBox>
                            </StackPane>
                        </VBox>

                        <!-- RIGHT MINI SUMMARY CARD -->
                        <VBox prefWidth="300" spacing="16" styleClass="summary-card">
                            <Label text="Appointment Summary" styleClass="card-title"/>

                            <VBox spacing="12" styleClass="summary-box">
                                <VBox spacing="4">
                                    <Label text="Patient" styleClass="summary-label"/>
                                 
                                    <TextField fx:id="patientIdField" promptText="Session patient id" editable="false" styleClass="modern-text-field"/>

                                </VBox>

                                <VBox spacing="4">
                                    <Label text="Doctor" styleClass="summary-label"/>
                                    <TextField fx:id="doctorField1" promptText="Enter doctor/staff id" styleClass="modern-text-field"/>
                                   
                                </VBox>

                                <VBox spacing="4">
                                    <Label text="Mode" styleClass="summary-label"/>
                                    <Label fx:id="selectedModeLabel" text="No mode selected" styleClass="summary-value"/>
                                </VBox>

                                <VBox spacing="4">
                                    <Label text="Selected date" styleClass="summary-label"/>
                                    <Label fx:id="selectedDateLabel" text="No date selected" styleClass="summary-value"/>
                                </VBox>

                                <VBox spacing="4">
                                    <Label text="Selected slot" styleClass="summary-label"/>
                                    <Label fx:id="selectedSlotLabel" text="No slot selected" styleClass="summary-value-highlight"/>
                                </VBox>
                            </VBox>

                        </VBox>

                        <!-- RIGHT MINI SUMMARY CARD -->
                        <VBox prefWidth="500" spacing="16" styleClass="summary-card">
                            <Label text="Docteurs List" styleClass="card-title"/>

                            <VBox spacing="12" styleClass="summary-box">
                                <!-- DOCTOR CARDS SECTION -->
                                <Label text="Select a Doctor" styleClass="card-title" style="-fx-padding: 16 0 0 0;"/>
                                <ScrollPane hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" styleClass="doctor-cards-scroll">
                                    <VBox fx:id="doctorCardsContainer" spacing="10" styleClass="doctor-cards-container">
                                        <!-- Dynamic doctor cards injected by ConsultationController -->
                                    </VBox>
                                </ScrollPane>
                            </VBox>

                        </VBox>
                    </HBox>

                    <!-- FORM CARD -->
                    <VBox spacing="18" styleClass="form-card">
                        <Label text="Appointment Details" styleClass="card-title"/>

                        <HBox spacing="18">
                            <VBox spacing="8" HBox.hgrow="ALWAYS">
                                <Label text="Mode" styleClass="field-label"/>
                                <ComboBox fx:id="modeComboBox" promptText="Select booking mode" styleClass="modern-combo-box" onAction="#handleModeSelection">
                                </ComboBox>
                                
                            </VBox>

                            <VBox spacing="8" HBox.hgrow="ALWAYS">
                                <Label text="Service / Doctor" styleClass="field-label"/>
                                <TextField fx:id="doctorField" promptText="Enter doctor or service" styleClass="modern-text-field"/>
                            </VBox>
                        </HBox>

                        <VBox spacing="8">
                            <Label text="Motif" styleClass="field-label"/>
                            <TextArea fx:id="motifArea"
                                      promptText="Describe the reason of the consultation..."
                                      prefRowCount="5"
                                      wrapText="true"
                                      styleClass="modern-text-area"/>
                        </VBox>

                        <HBox spacing="14" alignment="CENTER_RIGHT">
                            <Button text="Cancel" styleClass="cancel-button"/>
                            <Button text="Confirm Appointment" styleClass="confirm-button" onAction="#handleConfirmAppointment"/>
                        </HBox>
                    </VBox>
                        </VBox>

                        <!-- PAGE 2: MY BOOKINGS -->
                        <VBox spacing="24" styleClass="page-content" fx:id="myBookingsPage">
                            <HBox spacing="20" HBox.hgrow="ALWAYS" alignment="TOP_LEFT">
                                <VBox spacing="18" styleClass="booking-card" HBox.hgrow="ALWAYS">
                                    <Label text="My Appointments" styleClass="card-title"/>
                                    <Label text="Manage your rendez-vous for the current session patient." styleClass="helper-text"/>
                                    <HBox spacing="12" alignment="CENTER_LEFT">
                                        <TextField fx:id="myBookingsSearchField" promptText="Search rendez-vous..." styleClass="modern-text-field" HBox.hgrow="ALWAYS"/>
                                        <ComboBox fx:id="myBookingsSortComboBox" promptText="Tri..." prefWidth="190" styleClass="modern-combo-box"/>
                                    </HBox>
                                    <TableView fx:id="myBookingsTable" VBox.vgrow="ALWAYS" styleClass="my-bookings-table">
                                        <columns>
                                            <TableColumn fx:id="colId" text="ID" prefWidth="70"/>
                                            <TableColumn fx:id="colDateTime" text="Date &amp; Time" prefWidth="210"/>
                                            <TableColumn fx:id="colMode" text="Mode" prefWidth="110"/>
                                            <TableColumn fx:id="colMotif" text="Motif" prefWidth="230"/>
                                            <TableColumn fx:id="colStaff" text="Staff" prefWidth="80"/>
                                            <TableColumn fx:id="colStatut" text="Statut" prefWidth="110"/>
                                            <TableColumn fx:id="colActions" text="Actions" prefWidth="180"/>
                                        </columns>
                                    </TableView>
                                </VBox>

                                <VBox fx:id="modifyFormCard" prefWidth="500" spacing="16" styleClass="summary-card" visible="false" managed="false">
                                    <Label text="Modify Form" styleClass="card-title"/>

                                    <VBox spacing="12" styleClass="summary-box">
                                        <VBox spacing="6">
                                            <Label text="Patient ID" styleClass="field-label"/>
                                            <TextField fx:id="modifyPatientIdField" editable="false" styleClass="modern-text-field"/>
                                        </VBox>

                                        <VBox spacing="6">
                                            <Label text="Doctor/Staff ID" styleClass="field-label"/>
                                            <TextField fx:id="modifyStaffIdField" promptText="Enter doctor/staff id" styleClass="modern-text-field"/>
                                        </VBox>

                                        <VBox spacing="6">
                                            <Label text="Mode" styleClass="field-label"/>
                                            <ComboBox fx:id="modifyModeComboBox" promptText="Select booking mode" styleClass="modern-combo-box"/>
                                        </VBox>

                                        <VBox spacing="6">
                                            <Label text="Date Time" styleClass="field-label"/>
                                            <TextField fx:id="modifyDateTimeField" promptText="yyyy-MM-dd HH:mm" styleClass="modern-text-field"/>
                                        </VBox>

                                        <VBox spacing="6">
                                            <Label text="Motif" styleClass="field-label"/>
                                            <TextArea fx:id="modifyMotifArea" promptText="Edit motif..." prefRowCount="4" wrapText="true" styleClass="modern-text-area"/>
                                        </VBox>

                                        <HBox spacing="10" alignment="CENTER_RIGHT">
                                            <Button text="Cancel" styleClass="cancel-button" onAction="#handleCancelModify"/>
                                            <Button text="Confirm Modify" styleClass="confirm-button" onAction="#handleConfirmModify"/>
                                        </HBox>
                                    </VBox>
                                </VBox>
                            </HBox>
                            
                        </VBox>

                        <!-- PAGE 3: MY RECORDS -->
                        <VBox spacing="24" styleClass="page-content" fx:id="myRecordsPage" visible="false" managed="false">
                            <HBox spacing="20" HBox.hgrow="ALWAYS" alignment="TOP_LEFT">
                                <VBox spacing="18" styleClass="booking-card" HBox.hgrow="ALWAYS">
                                    <Label text="My Medical Records" styleClass="card-title"/>
                                    <Label text="Medical records linked to your booked rendez-vous." styleClass="helper-text"/>
                                    <HBox spacing="12" alignment="CENTER_LEFT">
                                        <TextField fx:id="myRecordsSearchField" promptText="Search medical records..." styleClass="modern-text-field" HBox.hgrow="ALWAYS"/>
                                        <ComboBox fx:id="myRecordsSortComboBox" promptText="Tri..." prefWidth="190" styleClass="modern-combo-box"/>
                                    </HBox>
                                    <TableView fx:id="myRecordsTable" VBox.vgrow="ALWAYS" styleClass="my-bookings-table">
                                        <columns>
                                            <TableColumn fx:id="recordColId" text="ID" prefWidth="70"/>
                                            <TableColumn fx:id="recordColRdvId" text="Rendez-vous" prefWidth="110"/>
                                            <TableColumn fx:id="recordColDateTime" text="Date &amp; Time" prefWidth="170"/>
                                            <TableColumn fx:id="recordColDiagnostic" text="Diagnostic" prefWidth="200"/>
                                            <TableColumn fx:id="recordColObservations" text="Observations" prefWidth="220"/>
                                            <TableColumn fx:id="recordColResults" text="Results" prefWidth="220"/>
                                            <TableColumn fx:id="recordColDuration" text="Duration" prefWidth="110"/>
                                            <TableColumn fx:id="recordColSignature" text="Signature" prefWidth="140"/>
                                            <TableColumn fx:id="recordColActions" text="Action" prefWidth="90"/>
                                        </columns>
                                    </TableView>

                                    <VBox fx:id="recordDetailsPanel" spacing="14" visible="false" managed="false" styleClass="summary-card">
                                        <Label text="Prescriptions of selected fiche medicale" styleClass="card-title"/>
                                        <Label fx:id="recordDetailsSummaryLabel" text="Select the arrow in the Action column to view prescriptions." styleClass="helper-text" wrapText="true"/>

                                        <TableView fx:id="recordPrescriptionsTable" VBox.vgrow="ALWAYS" styleClass="my-bookings-table">
                                            <columns>
                                                <TableColumn fx:id="recordPrescriptionNomColumn" text="Médicament" prefWidth="160"/>
                                                <TableColumn fx:id="recordPrescriptionDoseColumn" text="Dose" prefWidth="100"/>
                                                <TableColumn fx:id="recordPrescriptionFrequenceColumn" text="Fréquence" prefWidth="130"/>
                                                <TableColumn fx:id="recordPrescriptionInstructionsColumn" text="Instructions" prefWidth="220"/>
                                            </columns>
                                        </TableView>

                                        <Label fx:id="recordNoPrescriptionsLabel" text="There is no prescription for this fiche medicale." styleClass="empty-state-message" visible="false" managed="false" wrapText="true"/>
                                    </VBox>
                                </VBox>
                            </HBox>
                        </VBox>

                        
                    </StackPane>
                </VBox>
            </content>
        </ScrollPane>