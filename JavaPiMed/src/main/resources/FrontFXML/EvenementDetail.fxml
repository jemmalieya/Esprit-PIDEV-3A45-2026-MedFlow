<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/21"
            prefWidth="1400.0" prefHeight="820.0"
            stylesheets="@../CSS/booking.css"
            fx:controller="tn.esprit.controllers.EvenementController"
            styleClass="root-pane">

    <!-- LEFT SIDEBAR -->
    <left>
        <fx:include source="Sidebar.fxml"/>
    </left>

    <!-- MAIN BODY -->
    <center>
        <ScrollPane fitToWidth="true"
                    pannable="true"
                    hbarPolicy="NEVER"
                    vbarPolicy="AS_NEEDED"
                    styleClass="main-scroll">

            <content>
                <VBox spacing="24" styleClass="main-area">
                    <padding>
                        <Insets top="26" right="28" bottom="26" left="28"/>
                    </padding>

                    <!-- HEADER -->
                    <VBox spacing="6" styleClass="page-header">
                        <Label text="Détail événement" styleClass="page-title"/>
                        <Label text="Consultez les informations principales de cet événement."
                               wrapText="true"
                               styleClass="page-subtitle"/>
                    </VBox>

                    <!-- IMAGE + BADGES -->
                    <StackPane prefHeight="280"
                               style="-fx-background-color: linear-gradient(to bottom right, #dfeff5, #cfdde8);
                                      -fx-background-radius: 24;
                                      -fx-border-color: rgba(14,143,176,0.20);
                                      -fx-border-radius: 24;">

                        <ImageView fx:id="detailImageView"
                                   fitWidth="980"
                                   fitHeight="280"
                                   preserveRatio="false"
                                   smooth="true"/>

                        <HBox spacing="10" StackPane.alignment="TOP_LEFT">
                            <padding>
                                <Insets top="18" left="18"/>
                            </padding>

                            <Label fx:id="typeBadge"
                                   text="Type"
                                   style="-fx-background-color: rgba(255,255,255,0.92);
                                          -fx-background-radius: 999;
                                          -fx-padding: 6 14;
                                          -fx-text-fill: #0b5d73;
                                          -fx-font-weight: bold;"/>

                            <Label fx:id="statutBadge"
                                   text="Statut"
                                   style="-fx-background-color: rgba(255,255,255,0.92);
                                          -fx-background-radius: 999;
                                          -fx-padding: 6 14;
                                          -fx-text-fill: #0b5d73;
                                          -fx-font-weight: bold;"/>
                        </HBox>

                        <Label fx:id="dateBadge"
                               text="Dates"
                               StackPane.alignment="BOTTOM_RIGHT"
                               style="-fx-background-color: rgba(255,255,255,0.96);
                                      -fx-background-radius: 999;
                                      -fx-padding: 8 16;
                                      -fx-text-fill: #183c48;
                                      -fx-font-weight: bold;">
                            <StackPane.margin>
                                <Insets right="18" bottom="18"/>
                            </StackPane.margin>
                        </Label>
                    </StackPane>

                    <!-- TITLE BLOCK -->
                    <VBox spacing="10" styleClass="booking-card">

                    <Label fx:id="titreDetailLabel"
                               text="Titre événement"
                               style="-fx-text-fill: #153946; -fx-font-size: 28px; -fx-font-weight: 800;"/>

                        <HBox spacing="18">
                            <Label fx:id="villeDetailLabel"
                                   text="Ville"
                                   style="-fx-text-fill: #4d6d78; -fx-font-size: 14px; -fx-font-weight: 600;"/>

                            <Label fx:id="adresseDetailLabel"
                                   text="Adresse"
                                   style="-fx-text-fill: #4d6d78; -fx-font-size: 14px; -fx-font-weight: 600;"/>

                            <Label fx:id="visibiliteDetailLabel"
                                   text="Visibilité"
                                   style="-fx-text-fill: #4d6d78; -fx-font-size: 14px; -fx-font-weight: 600;"/>
                        </HBox>
                    </VBox>

                    <!-- CONTENT -->
                    <HBox spacing="20">
                        <!-- LEFT -->
                        <VBox spacing="20" HBox.hgrow="ALWAYS" prefWidth="820">
                            <VBox spacing="12" styleClass="booking-card">
                                <Label text="Description" styleClass="card-title"/>
                                <Label fx:id="descriptionDetailLabel"
                                       text="Description..."
                                       wrapText="true"
                                       style="-fx-text-fill: #4d6d78; -fx-font-size: 14px;"/>
                            </VBox>

                            <VBox spacing="12" styleClass="booking-card">
                                <Label text="Objectif" styleClass="card-title"/>
                                <Label fx:id="objectifDetailLabel"
                                       text="Objectif..."
                                       wrapText="true"
                                       style="-fx-text-fill: #4d6d78; -fx-font-size: 14px;"/>
                            </VBox>

                            <VBox spacing="12" styleClass="ai-front-card">
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <Label text="Recommandations IA" styleClass="card-title"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Label fx:id="aiFrontStatusLabel"
                                           text="Analyse locale"
                                           wrapText="true"
                                           styleClass="ai-status-chip"/>
                                </HBox>
                                <FlowPane fx:id="aiFrontRecommendationsContainer"
                                          hgap="12"
                                          vgap="12"
                                          prefWrapLength="780"/>
                            </VBox>

                            <VBox spacing="12" styleClass="event-map-card">
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <Label text="Carte et accès" styleClass="card-title"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Button text="-"
                                            onAction="#zoomArriereCarteEvenement"
                                            styleClass="event-map-tool-button"/>
                                    <Button text="+"
                                            onAction="#zoomAvantCarteEvenement"
                                            styleClass="event-map-tool-button"/>
                                    <Button text="Depuis ma position"
                                            onAction="#ouvrirItineraireEvenement"
                                            styleClass="event-link-button"/>
                                    <Button text="Ouvrir la carte"
                                            onAction="#ouvrirCarteEvenement"
                                            styleClass="event-link-button"/>
                                </HBox>
                                <StackPane minHeight="390" prefHeight="390" styleClass="event-map-frame">
                                    <ImageView fx:id="mapImageView"
                                               fitWidth="820"
                                               fitHeight="390"
                                               preserveRatio="false"
                                               smooth="true"/>
                                    <Label fx:id="mapStatusLabel"
                                           text="Chargement de la carte..."
                                           wrapText="true"
                                           StackPane.alignment="BOTTOM_LEFT"
                                           styleClass="event-map-status"/>
                                </StackPane>
                            </VBox>
                        </VBox>

                        <!-- RIGHT -->
                        <VBox spacing="18" prefWidth="320">
                            <VBox spacing="12" styleClass="summary-card">
                                <Label text="Informations rapides" styleClass="card-title"/>

                                <Label fx:id="organisateurDetailLabel"
                                       text="Organisateur"
                                       wrapText="true"
                                       style="-fx-text-fill: #183c48; -fx-font-size: 14px; -fx-font-weight: 700;"/>

                                <Label fx:id="emailDetailLabel"
                                       text="Email"
                                       wrapText="true"
                                       style="-fx-text-fill: #4d6d78; -fx-font-size: 13px;"/>

                                <Label fx:id="telDetailLabel"
                                       text="Téléphone"
                                       wrapText="true"
                                       style="-fx-text-fill: #4d6d78; -fx-font-size: 13px;"/>

                                <Label fx:id="nbPlacesDetailLabel"
                                       text="Participants max"
                                       wrapText="true"
                                       style="-fx-text-fill: #4d6d78; -fx-font-size: 13px;"/>

                                <Label fx:id="inscriptionDetailLabel"
                                       text="Inscription"
                                       wrapText="true"
                                       style="-fx-text-fill: #4d6d78; -fx-font-size: 13px;"/>

                                <Label fx:id="dateLimiteDetailLabel"
                                       text="Date limite"
                                       wrapText="true"
                                       style="-fx-text-fill: #4d6d78; -fx-font-size: 13px;"/>
                            </VBox>

                            <VBox spacing="12" styleClass="weather-card">
                                <Label text="Météo du lieu" styleClass="card-title"/>
                                <Label fx:id="weatherConditionLabel" text="Chargement..." wrapText="true" styleClass="weather-main-label"/>
                                <HBox spacing="8">
                                    <Label fx:id="weatherTempLabel" text="-" styleClass="weather-chip"/>
                                    <Label fx:id="weatherHumidityLabel" text="-" styleClass="weather-chip"/>
                                </HBox>
                                <Label fx:id="weatherWindLabel" text="-" wrapText="true" styleClass="weather-note-label"/>
                            </VBox>

                            <HBox spacing="12">
                                <Button text="Retour"
                                        onAction="#retourVersListeFrontFixe"
                                        styleClass="cancel-button"/>

                                <Region HBox.hgrow="ALWAYS"/>

                                <Button text="Participer"
                                        onAction="#ouvrirFormulaireParticipation"
                                        styleClass="confirm-button"/>
                            </HBox>
                        </VBox>
                    </HBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>
