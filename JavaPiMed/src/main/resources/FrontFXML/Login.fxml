<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.LoginController"
            fx:id="rootPane"
            prefHeight="720.0"
            prefWidth="1280.0"
            minWidth="900.0"
            minHeight="600.0"
            stylesheets="@../CSS/login.css"
            styleClass="auth-page-login">

    <HBox fx:id="mainContent" alignment="CENTER" spacing="0.0"
          AnchorPane.bottomAnchor="40.0"
          AnchorPane.leftAnchor="56.0"
          AnchorPane.rightAnchor="56.0"
          AnchorPane.topAnchor="40.0">

        <!-- ── Visual / Branding Panel ── -->
        <VBox fx:id="visualPanel" prefWidth="480.0" spacing="18.0"
              styleClass="auth-visual-login" HBox.hgrow="ALWAYS">
            <padding>
                <Insets top="40.0" right="38.0" bottom="40.0" left="38.0"/>
            </padding>

            <!-- Brand badge -->
            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <HBox styleClass="auth-brand-badge" maxWidth="180" alignment="CENTER">
                    <Label text="✦  MEDFLOW" styleClass="auth-visual-brand"/>
                </HBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="themeToggleBtn"
                        text="Mode clair"
                        onAction="#handleToggleTheme"
                        styleClass="theme-toggle-auth"/>
            </HBox>

            <Label text="Connexion" styleClass="auth-visual-title"/>
            <Label text="Acces securise a votre espace patient.&#xA;Vos donnees, vos rendez-vous, vos dossiers."
                   styleClass="auth-visual-subtitle" wrapText="true"/>

            <Region VBox.vgrow="ALWAYS"/>

            <!-- Note card at bottom of visual -->
            <VBox spacing="6.0" styleClass="auth-visual-note">
                <Label text="🔒  Connexion rapide" styleClass="auth-visual-note-title"/>
                <Label text="Acces chiffre · Authentification faciale disponible · Google OAuth"
                       styleClass="auth-visual-note-text" wrapText="true"/>
            </VBox>
        </VBox>

        <!-- ── Form Panel ── -->
        <VBox fx:id="formPanel" prefWidth="500.0" spacing="14.0"
              styleClass="auth-form-panel" HBox.hgrow="ALWAYS">
            <padding>
                <Insets top="44.0" right="48.0" bottom="44.0" left="48.0"/>
            </padding>

            <Label text="Bon retour 👋" styleClass="auth-form-title"/>
            <Label text="Connectez-vous a votre compte MedFlow." styleClass="auth-form-subtitle"/>

            <Region minHeight="6" maxHeight="6"/>

            <!-- Email -->
            <VBox spacing="5.0">
                <Label text="ADRESSE E-MAIL" styleClass="field-label-login"/>
                <TextField fx:id="emailField" promptText="vous@example.com" styleClass="login-field"/>
                <Label fx:id="emailErrorLabel" managed="false" styleClass="field-error"
                       text="" visible="false" wrapText="true"/>
            </VBox>

            <!-- Password -->
            <VBox spacing="5.0">
                <Label text="MOT DE PASSE" styleClass="field-label-login"/>
                <PasswordField fx:id="passwordField" promptText="••••••••••" styleClass="login-field"/>
                <Label fx:id="passwordErrorLabel" managed="false" styleClass="field-error"
                       text="" visible="false" wrapText="true"/>
            </VBox>

            <!-- Remember + Forgot -->
            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <CheckBox fx:id="rememberMeCheckBox" styleClass="remember-check" text="Se souvenir de moi"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Hyperlink onAction="#handleForgotPassword" styleClass="login-link" text="Mot de passe oublie ?"/>
            </HBox>

            <!-- reCAPTCHA temporairement masque (bloc conserve pour reactivation) -->
            <!--
            <VBox fx:id="recaptchaContainer" spacing="4.0">
                <Label text="Verification anti-bot" styleClass="field-label-login"/>
                <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="recaptcha-row">
                    <Button fx:id="openRecaptchaBtn" onAction="#handleOpenRecaptchaModal"
                            styleClass="recaptcha-open-btn" text="Verifier maintenant"/>
                    <Label fx:id="recaptchaStateLabel" styleClass="recaptcha-state recaptcha-pending" text="Non verifie"/>
                </HBox>
            </VBox>
            -->

            <!-- Status -->
            <Label fx:id="statusLabel" managed="false" styleClass="status-message"
                   text="" visible="false" wrapText="true"/>

            <!-- Primary actions -->
            <HBox spacing="10.0">
                <Button HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308"
                        onAction="#handleClear" styleClass="secondary-action" text="Effacer"/>
                <Button HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308"
                        onAction="#handleLogin" styleClass="primary-action" text="Se connecter →"/>
            </HBox>

            <!-- Google -->
            <Button maxWidth="1.7976931348623157E308"
                    onAction="#handleGoogleLogin" styleClass="google-action"
                    text="G  Continuer avec Google" VBox.vgrow="NEVER"/>

            <!-- Face login -->
            <Button maxWidth="1.7976931348623157E308"
                    onAction="#handleFaceLogin" styleClass="face-action"
                    text="🎯  Connexion Faciale" VBox.vgrow="NEVER"/>

            <Region VBox.vgrow="ALWAYS"/>

            <!-- Register link -->
            <HBox alignment="CENTER" spacing="6.0">
                <Label styleClass="register-label" text="Pas encore de compte ?"/>
                <Hyperlink onAction="#handleOpenRegister" styleClass="login-link-secondary" text="Creer un compte"/>
            </HBox>
        </VBox>
    </HBox>
</AnchorPane>
