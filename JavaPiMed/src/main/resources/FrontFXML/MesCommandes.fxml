<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.CommandeController"
            stylesheets="@../CSS/commandes.css,@../CSS/booking.css"
            styleClass="cmd-root"
            prefWidth="1400.0" prefHeight="820.0">

    <!-- SIDEBAR -->
    <left>
        <fx:include source="Sidebar.fxml"/>
    </left>

    <!-- CENTER -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="cmd-scroll">
            <content>
                <VBox spacing="24" styleClass="cmd-main">
                    <padding>
                        <Insets top="25" right="30" bottom="25" left="30"/>
                    </padding>

                    <!-- HEADER BLEU -->
                    <VBox alignment="CENTER" spacing="10" styleClass="cmd-header">
                        <Label text="📦" styleClass="cmd-icon"/>
                        <Label text="Mes commandes" styleClass="cmd-title"/>
                        <Label text="Suivez l'état de vos commandes"
                               styleClass="cmd-subtitle"/>
                    </VBox>

                    <!-- HERO -->
                    <HBox spacing="18" alignment="CENTER_LEFT" styleClass="hero-card">
                        <children>
                            <VBox spacing="8" HBox.hgrow="ALWAYS">
                                <children>
                                    <Label text="📦 Gestion des commandes" styleClass="hero-title"/>
                                    <Label text="Suivez vos achats, consultez les détails et gérez vos livraisons."
                                           wrapText="true"
                                           styleClass="hero-subtitle"/>
                                </children>
                            </VBox>

                            <Button fx:id="btnPanierCommandes"
                                    text="🛒 Panier (0)"
                                    onAction="#ouvrirPanierPopup"
                                    styleClass="hero-cart-btn"/>
                        </children>
                        <Button text="🏪 Retour pharmacie"
                                onAction="#retourPharmacie"
                                styleClass="hero-cart-btn"/>
                    </HBox>

                    <!-- COMMANDES -->
                    <FlowPane fx:id="commandeContainer"
                              hgap="20"
                              vgap="20"
                              prefWrapLength="1000"/>
                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>