<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import java.net.URL?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/21"
            prefWidth="1400.0" prefHeight="820.0"
            fx:controller="tn.esprit.controllers.EvenementController"
            styleClass="root-pane">
    <stylesheets>
        <URL value="@../CSS/booking.css"/>
        <URL value="@../CSS/evenement.css"/>
    </stylesheets>

    <left>
        <fx:include source="Sidebar.fxml"/>
    </left>

    <center>
        <ScrollPane fitToWidth="true"
                    pannable="true"
                    hbarPolicy="NEVER"
                    vbarPolicy="AS_NEEDED"
                    styleClass="main-scroll">
            <content>
                <VBox spacing="24" styleClass="main-area">
                    <padding>
                        <Insets top="26" right="28" bottom="26" left="28"/>
                    </padding>

                    <HBox spacing="18" alignment="CENTER_LEFT" styleClass="page-header participations-header">
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="Mes participations" styleClass="page-title participations-header-title"/>
                            <Label fx:id="participationSummaryLabel"
                                   text="Suivez vos demandes, vos decisions et vos tickets QR."
                                   wrapText="true"
                                   styleClass="page-subtitle participations-header-subtitle"/>
                        </VBox>
                        <Button text="Retour événements"
                                onAction="#retourVersListeFrontFixe"
                                styleClass="event-my-participations-button"/>
                    </HBox>

                    <FlowPane fx:id="participationsContainer"
                              hgap="18"
                              vgap="18"
                              prefWrapLength="1080"/>

                    <Region minHeight="20"/>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
