<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.ReclamationListController"
            stylesheets="@../CSS/reclamation.css,@../CSS/booking.css"
            styleClass="root-pane">

    <left>
        <fx:include source="Sidebar.fxml"/>
    </left>

    <center>

        <VBox spacing="20" styleClass="main-area">

            <padding>
                <Insets top="25" right="30" bottom="25" left="30"/>
            </padding>

            <!-- ================= HEADER ================= -->
            <VBox spacing="8" styleClass="page-header">
                <Label text="📊 Liste des Réclamations"
                       styleClass="page-title"/>

                <Label text="Gestion complète"
                       styleClass="page-subtitle"/>
            </VBox>



            <!-- TABLE CARD -->
            <VBox styleClass="table-card">

                <TableView fx:id="tableReclamations" prefHeight="500">

                    <columns>
                        <TableColumn fx:id="colContenu" text="Contenu" prefWidth="150"/>
                        <TableColumn fx:id="colDescription" text="Description" prefWidth="200"/>
                        <TableColumn fx:id="colType" text="Type" prefWidth="120"/>
                        <TableColumn fx:id="colStatut" text="Statut" prefWidth="120"/>
                        <TableColumn fx:id="colPriorite" text="Priorité" prefWidth="120"/>
                        <TableColumn fx:id="colActions" text="Actions" prefWidth="160"/>
                    </columns>

                </TableView>

            </VBox>

        </VBox>

    </center>

</BorderPane>