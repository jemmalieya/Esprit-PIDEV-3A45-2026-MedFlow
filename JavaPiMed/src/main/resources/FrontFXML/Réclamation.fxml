<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.ReclamationController"
            stylesheets="@../CSS/reclamation.css,@../CSS/booking.css"
            styleClass="root-pane"
            prefWidth="1400" prefHeight="820">

    <!-- SIDEBAR (INCHANGÉ) -->
    <left>
        <fx:include source="Sidebar.fxml"/>
    </left>

    <!-- ================= CENTER ================= -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="main-scroll">
            <content>

                <VBox spacing="18" styleClass="main-area">

                    <padding>
                        <Insets top="25" right="30" bottom="25" left="30"/>
                    </padding>

                    <!-- ================= HEADER ================= -->
                    <VBox spacing="8" styleClass="page-header">
                        <Label text="📋 Gestion des Réclamations"
                               styleClass="page-title"/>

                        <Label text="Créer une nouvelle réclamation rapidement"
                               styleClass="page-subtitle"/>
                    </VBox>

                    <!-- ================= FORM CENTERED ================= -->
                    <HBox alignment="CENTER">

                        <VBox spacing="15"
                              styleClass="info-card"
                              prefWidth="500">

                            <Label text="➕ Nouvelle Réclamation"
                                   styleClass="info-title"/>

                            <VBox spacing="5">
                                <Label text="Contenu" styleClass="input-label"/>
                                <TextField fx:id="tfContenu" styleClass="modern-input"/>
                                <Label fx:id="errContenu" styleClass="error-label"/>
                            </VBox>

                            <VBox spacing="5">
                                <Label text="Description" styleClass="input-label"/>
                                <TextArea fx:id="taDescription" styleClass="modern-input"/>
                                <Label fx:id="errDescription" styleClass="error-label"/>
                            </VBox>

                            <VBox spacing="5">
                                <Label text="Type" styleClass="input-label"/>
                                <ComboBox fx:id="cbType" styleClass="modern-combo"/>
                                <Label fx:id="errType" styleClass="error-label"/>
                            </VBox>

                            <Button text="➕ Envoyer la Réclamation"
                                    onAction="#ajouterReclamation"
                                    styleClass="hero-cart-btn"/>

                            <Button text="❌ Annuler "
                                    onAction="#goToList"
                                    styleClass="cancel-btn"/>

                            <HBox spacing="10">

                                <!-- 🔥 NAVIGATION VERS LISTE -->
                                <Button text="📊 Voir toutes les réclamations"
                                        onAction="#goToList"
                                        styleClass="voice-btn"/>

                                <Button text="🧹 Vider"
                                        onAction="#viderChamps"
                                        styleClass="voice-btn"/>
                            </HBox>

                            <Label fx:id="lblMessage"/>
                        </VBox>

                    </HBox>

                </VBox>

            </content>
        </ScrollPane>
    </center>

</BorderPane>