<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      prefWidth="245.0"
      styleClass="sidebar"
      fx:controller="tn.esprit.controllers.NavigationController">

    <padding>
        <Insets top="28" right="18" bottom="28" left="18"/>
    </padding>

    <!-- Header card: front = logo, back = user info (flip on hover) -->
    <StackPane fx:id="sidebarCard"
               prefHeight="80.0" minHeight="80.0" maxHeight="80.0"
               style="-fx-background-radius: 18; -fx-background-color: rgba(15,23,42,0.10); -fx-padding: 10 12 10 12;">
        <!-- FRONT: logo -->
        <VBox fx:id="sidebarCardFront" spacing="4" alignment="CENTER_LEFT">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <ImageView fitWidth="40" fitHeight="40" preserveRatio="true">
                    <image>
                        <Image url="/images/logo.png"/>
                    </image>
                </ImageView>
                <VBox spacing="2">
                    <Label text="MEDFLOW" styleClass="logo-text"/>
                    <Label text="Healthcare Platform" styleClass="logo-subtext"/>
                </VBox>
            </HBox>
            <Label text="Passer la souris pour voir le profil"
                   style="-fx-text-fill: #e0f2fe; -fx-font-size: 10px; -fx-opacity: 0.8;"/>
        </VBox>

        <!-- BACK: user info -->
        <HBox fx:id="sidebarCardBack" spacing="10" alignment="CENTER_LEFT">
            <StackPane prefWidth="36" prefHeight="36"
                       style="-fx-background-radius: 18; -fx-background-color: #0ea5e9; -fx-border-color: rgba(255,255,255,0.65); -fx-border-width: 1; -fx-border-radius: 18;">
                <children>
                    <ImageView fx:id="sidebarProfileImage" fitWidth="32" fitHeight="32" preserveRatio="true"/>
                    <Label fx:id="sidebarInitialsLabel"
                           text="MF"
                           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                </children>
            </StackPane>
            <VBox spacing="2">
                <Label fx:id="sidebarNameLabel" text="MedFlow Admin"
                       style="-fx-text-fill: #e0f2fe; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                <Label fx:id="sidebarRoleLabel" text="Administrateur"
                       style="-fx-text-fill: #bae6fd; -fx-font-size: 11px;"/>
            </VBox>
        </HBox>
    </StackPane>

    <VBox spacing="12" styleClass="menu-box">
        <padding>
            <Insets top="35"/>
        </padding>

        <Button fx:id="accueilButton" text="Accueil" styleClass="menu-button" onAction="#handleAccueil"/>
        <Button fx:id="reclamationButton" text="Réclamation" styleClass="menu-button" onAction="#handleRéclamation"/>
        <Button fx:id="blogButton" text="Blog" styleClass="menu-button" onAction="#handleBlog"/>
        <Button fx:id="pharmacieButton" text="Pharmacie" styleClass="menu-button" onAction="#handlePharmacie"/>
        <Button fx:id="evenementButton" text="Événement" styleClass="menu-button" onAction="#handleÉvénement"/>
        <Button fx:id="consultationButton" text="Consultation" styleClass="menu-button" onAction="#handleRendezVous"/>
        <Button fx:id="compteButton" text="Compte" styleClass="menu-button" onAction="#handleCompte"/>
    </VBox>

    <VBox VBox.vgrow="ALWAYS"/>

    <VBox spacing="10">
        <Button text="Mon Compte" styleClass="menu-button" onAction="#handleCompte"/>
        <Button text="Se déconnecter" styleClass="menu-button" onAction="#handleLogout"/>
    </VBox>
</VBox>