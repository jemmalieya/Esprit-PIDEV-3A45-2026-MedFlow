<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import java.net.URL?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/21"
            prefWidth="1400.0" prefHeight="820.0"
            fx:controller="tn.esprit.controllers.EvenementController"
            styleClass="root-pane">
    <stylesheets>
        <URL value="@../CSS/booking.css"/>
        <URL value="@../CSS/evenement.css"/>
    </stylesheets>
    <Label fx:id="frontPageMarker" visible="false" managed="false"/>

    <!-- LEFT SIDEBAR -->
    <left>
        <fx:include source="Sidebar.fxml"/>
    </left>

    <!-- MAIN BODY -->
    <center>
        <ScrollPane fitToWidth="true"
                    pannable="true"
                    hbarPolicy="NEVER"
                    vbarPolicy="AS_NEEDED"
                    styleClass="main-scroll">

            <content>
                <VBox spacing="24" styleClass="main-area">
                    <padding>
                        <Insets top="26" right="28" bottom="26" left="28"/>
                    </padding>

                    <!-- ✅ KEEP YOUR ORIGINAL TEAL HEADER -->
                    <HBox spacing="18" alignment="CENTER_LEFT" styleClass="page-header">
                        <StackPane minWidth="84" minHeight="84" prefWidth="84" prefHeight="84" styleClass="page-header-icon-wrap">
                            <Label text="EVT" styleClass="page-header-icon"/>
                        </StackPane>
                        <VBox spacing="8" HBox.hgrow="ALWAYS">
                            <Label text="Evenements MedFlow" styleClass="page-title"/>
                            <Label text="Consultez les evenements disponibles, suivez vos demandes de participation et accedez rapidement a vos notifications."
                                   wrapText="true"
                                   styleClass="page-subtitle"/>
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Label text="Catalogue en direct" styleClass="page-header-pill"/>
                                <Label text="Participation simplifiee" styleClass="page-header-pill-soft"/>
                                <Label text="Suivi personnel" styleClass="page-header-pill-soft"/>
                            </HBox>
                        </VBox>
                        <VBox fx:id="eventUpdateToast"
                              visible="false"
                              managed="false"
                              spacing="4"
                              styleClass="event-update-toast">
                            <Label text="Mise a jour evenement" styleClass="event-update-toast-title"/>
                            <Label text="Un evenement de vos participations a change. Consultez Mes participations."
                                   wrapText="true"
                                   styleClass="event-update-toast-message"/>
                        </VBox>
                        <VBox spacing="10" alignment="CENTER_RIGHT" styleClass="event-front-actions">
                            <Button text="Evenements passes"
                                    onAction="#ouvrirEvenementsPasses"
                                    wrapText="true"
                                    minWidth="190.0"
                                    styleClass="event-front-secondary-button"/>
                            <StackPane alignment="TOP_RIGHT" styleClass="event-front-button-shell">
                                <Button text="Notifications"
                                        onAction="#ouvrirNotificationsEvenement"
                                        wrapText="true"
                                        minWidth="190.0"
                                        styleClass="event-front-secondary-button"/>
                                <Label fx:id="notificationBadgeLabel"
                                       text="0"
                                       visible="false"
                                       managed="false"
                                       styleClass="event-front-notification-badge"
                                       StackPane.alignment="TOP_RIGHT"/>
                            </StackPane>
                            <Button text="Mes participations"
                                    onAction="#ouvrirMesParticipations"
                                    wrapText="true"
                                    minWidth="190.0"
                                    styleClass="event-front-primary-button"/>
                        </VBox>
                    </HBox>

                    <!-- TITLE -->
                    <VBox spacing="8" styleClass="events-intro-card">
                        <Label text="Evenements a venir" styleClass="events-intro-title"/>
                        <Label text="Retrouvez ici l'ensemble des evenements publies, classes pour vous aider a choisir rapidement ceux qui vous interessent."
                               wrapText="true"
                               styleClass="events-intro-text"/>
                    </VBox>

                    <!-- ✅ EVENT CARDS FROM DATABASE -->
                    <FlowPane fx:id="cardsContainer"
                              hgap="20"
                              vgap="20"
                              prefWrapLength="1100">
                    </FlowPane>

                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>
