<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import java.net.URL?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/21"
            prefWidth="1400.0" prefHeight="820.0"
            fx:controller="tn.esprit.controllers.EvenementController"
            styleClass="root-pane">
    <stylesheets>
        <URL value="@../CSS/booking.css"/>
        <URL value="@../CSS/evenement.css"/>
    </stylesheets>
    <Label fx:id="frontPageMarker" visible="false" managed="false"/>

    <!-- LEFT SIDEBAR -->
    <left>
        <fx:include source="Sidebar.fxml"/>
    </left>

    <!-- MAIN BODY -->
    <center>
        <ScrollPane fitToWidth="true"
                    pannable="true"
                    hbarPolicy="NEVER"
                    vbarPolicy="AS_NEEDED"
                    styleClass="main-scroll">

            <content>
                <VBox spacing="24" styleClass="main-area">
                    <padding>
                        <Insets top="26" right="28" bottom="26" left="28"/>
                    </padding>

                    <!-- ✅ KEEP YOUR ORIGINAL TEAL HEADER -->
                    <HBox spacing="18" alignment="CENTER_LEFT" styleClass="page-header">
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="Evenement" styleClass="page-title"/>
                            <Label text="Decouvrez les evenements MedFlow et suivez vos demandes de participation."
                                   wrapText="true"
                                   styleClass="page-subtitle"/>
                        </VBox>
                        <VBox fx:id="eventUpdateToast"
                              visible="false"
                              managed="false"
                              spacing="4"
                              styleClass="event-update-toast">
                            <Label text="Mise a jour evenement" styleClass="event-update-toast-title"/>
                            <Label text="Un evenement de vos participations a change. Consultez Mes participations."
                                   wrapText="true"
                                   styleClass="event-update-toast-message"/>
                        </VBox>
                        <VBox spacing="10" alignment="CENTER_RIGHT" styleClass="event-front-actions">
                            <StackPane alignment="TOP_RIGHT" styleClass="event-front-button-shell">
                                <Button text="Notifications"
                                        onAction="#ouvrirNotificationsEvenement"
                                        wrapText="true"
                                        minWidth="190.0"
                                        styleClass="event-front-secondary-button"/>
                                <Label fx:id="notificationBadgeLabel"
                                       text="0"
                                       visible="false"
                                       managed="false"
                                       styleClass="event-front-notification-badge"
                                       StackPane.alignment="TOP_RIGHT"/>
                            </StackPane>
                            <Button text="Mes participations"
                                    onAction="#ouvrirMesParticipations"
                                    wrapText="true"
                                    minWidth="190.0"
                                    styleClass="event-front-primary-button"/>
                        </VBox>
                    </HBox>

                    <!-- TITLE -->
                    <VBox spacing="6">
                        <Label text="Upcoming Events" style="-fx-font-size:18px; -fx-font-weight: bold;"/>
                        <Label text="Discover all events added from the database."
                               style="-fx-text-fill:#6e8c97;"/>
                    </VBox>

                    <!-- ✅ EVENT CARDS FROM DATABASE -->
                    <FlowPane fx:id="cardsContainer"
                              hgap="20"
                              vgap="20"
                              prefWrapLength="1100">
                    </FlowPane>

                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>
