<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="rootPane"
            prefWidth="1500.0"
            prefHeight="880.0"
            styleClass="app-root"
            stylesheets="@CSS/admin-welcome.css,@CSS/pending-posts-center.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.PendingPostsAdminController">

    <left>
        <BorderPane prefWidth="320.0" styleClass="sidebar">

            <top>
                <VBox spacing="8">
                    <padding>
                        <Insets top="26" right="20" bottom="16" left="20"/>
                    </padding>

                    <Label text="MedFlow Admin" styleClass="brand-title"/>
                    <Label text="ESPACE ADMINISTRATION" styleClass="brand-subtitle"/>
                    <Separator styleClass="side-separator"/>
                </VBox>
            </top>

            <center>
                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" styleClass="sidebar-scroll">
                    <content>
                        <VBox spacing="10">
                            <padding>
                                <Insets top="4" right="18" bottom="16" left="18"/>
                            </padding>

                            <Button text="Accueil Admin" onAction="#openDashboard" styleClass="nav-button-active"/>

                            <TitledPane text="Utilisateurs" expanded="false" styleClass="sidebar-dropdown">
                                <content>
                                    <VBox spacing="6" styleClass="dropdown-content">
                                        <Button text="Patients" onAction="#openPatients" styleClass="sub-nav-button"/>
                                        <Button text="Tous les utilisateurs" onAction="#openUsers" styleClass="sub-nav-button"/>
                                        <Button text="Demandes de rôle" onAction="#openRoles" styleClass="sub-nav-button"/>
                                        <Button text="Comptes et permissions" onAction="#openUserRoles" styleClass="sub-nav-button"/>
                                    </VBox>
                                </content>
                            </TitledPane>

                            <TitledPane text="Produits" expanded="true" styleClass="sidebar-dropdown">
                                <content>
                                    <VBox spacing="6" styleClass="dropdown-content">
                                        <Button text="Liste des produits" onAction="#openProduits" styleClass="sub-nav-button"/>
                                        <Button text="Commandes" onAction="#openCommandes" styleClass="sub-nav-button"/>
                                        <Button text="Détection Épidémie" onAction="#openDetection" styleClass="sub-nav-button"/>
                                        <Button text="Stock et ruptures" onAction="#openStockRupture" styleClass="sub-nav-button"/>
                                        <Button text="Statistiques produits" onAction="#openStatsProduits" styleClass="sub-nav-button"/>
                                    </VBox>
                                </content>
                            </TitledPane>

                            <TitledPane text="Événements" expanded="false" styleClass="sidebar-dropdown">
                                <content>
                                    <VBox spacing="6" styleClass="dropdown-content">
                                        <Button text="Liste des événements" onAction="#openEvents" styleClass="sub-nav-button"/>
                                        <Button text="Participants demandes" onAction="#openEventParticipants" styleClass="sub-nav-button"/>
                                        <Button text="Ressources" onAction="#openRessources" styleClass="sub-nav-button"/>
                                        <Button text="Stats événements" onAction="#openStatsEvents" styleClass="sub-nav-button"/>
                                        <Button text="Stats ressources" onAction="#openStatsRessources" styleClass="sub-nav-button"/>
                                    </VBox>
                                </content>
                            </TitledPane>

                            <TitledPane text="Consultations" expanded="false" styleClass="sidebar-dropdown">
                                <content>
                                    <VBox spacing="6" styleClass="dropdown-content">
                                        <Button text="Consultations par Docteur" onAction="#openConsultations" styleClass="sub-nav-button"/>
                                        <Button text="Rendez-vous" onAction="#openRendezVous" styleClass="sub-nav-button"/>
                                        <Button text="Statistiques consultations" onAction="#openStatsConsultations" styleClass="sub-nav-button"/>
                                    </VBox>
                                </content>
                            </TitledPane>

                            <TitledPane text="Réclamations" expanded="false" styleClass="sidebar-dropdown">
                                <content>
                                    <VBox spacing="6" styleClass="dropdown-content">
                                        <Button text="Liste des réclamations" onAction="#openReclamations" styleClass="sub-nav-button"/>
                                        <Button text="Statistiques réclamations" onAction="#openStatsReclamations" styleClass="sub-nav-button"/>
                                    </VBox>
                                </content>
                            </TitledPane>

                            <TitledPane text="Blog et Posts" expanded="true" styleClass="sidebar-dropdown">
                                <content>
                                    <VBox spacing="6" styleClass="dropdown-content">
                                        <Button text="Liste des posts" onAction="#openPosts" styleClass="sub-nav-button"/>
                                        <Button text="Posts en attente" styleClass="sub-nav-button" style="-fx-background-color: rgba(20, 184, 166, 0.25); -fx-text-fill: white;"/>
                                        <Button text="Statistiques blog" onAction="#openStatsBlog" styleClass="sub-nav-button"/>
                                    </VBox>
                                </content>
                            </TitledPane>

                            <Button text="Déconnexion" onAction="#logout" styleClass="logout-button"/>
                        </VBox>
                    </content>
                </ScrollPane>
            </center>

            <bottom>
                <VBox spacing="10">
                    <padding>
                        <Insets top="12" right="18" bottom="22" left="18"/>
                    </padding>

                    <Separator styleClass="side-separator"/>
                    <Button text="Retour Site" onAction="#goBackSite" styleClass="back-site-button"/>
                </VBox>
            </bottom>

        </BorderPane>
    </left>

    <top>
        <HBox alignment="CENTER_LEFT" spacing="18" styleClass="top-bar">
            <padding>
                <Insets top="18" right="28" bottom="18" left="28"/>
            </padding>

            <Button text="Menu" styleClass="menu-button"/>

            <VBox spacing="3">
                <Label text="Modération des Posts" styleClass="page-title"/>
                <Label text="Validez et modérez les posts envoyés par les patients" styleClass="page-subtitle"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <TextField promptText="Rechercher..." styleClass="search-field"/>
            <Button text="Notif" styleClass="icon-button"/>
            <Button text="Param" styleClass="icon-button"/>
            <Label text="A" styleClass="avatar-label"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="content-scroll">
            <content>
                <VBox spacing="24" styleClass="simple-home-content">
                    <padding>
                        <Insets top="34" right="38" bottom="45" left="38"/>
                    </padding>

                    <!-- Welcome Card -->
                    <VBox id="welcomeBanner" spacing="16" styleClass="simple-welcome-card">
                        <HBox spacing="16" alignment="CENTER_LEFT">
                            <StackPane prefWidth="64" prefHeight="64" styleClass="welcome-icon-container">
                                <Label text="📰" styleClass="welcome-icon"/>
                            </StackPane>
                            <VBox spacing="8" HBox.hgrow="ALWAYS">
                                <Label text="Posts en Attente de Modération" styleClass="simple-welcome-title"/>
                                <Label text="Gérez et modérez les posts soumis par les patients avec précision et efficacité." styleClass="simple-welcome-text"/>
                            </VBox>
                        </HBox>
                        <Label text="Utilisez les boutons d'action pour approuver ou refuser les publications. Chaque décision contribue à maintenir la qualité de notre plateforme médicale."
                               wrapText="true"
                               styleClass="simple-welcome-subtext"/>
                        <HBox spacing="12" alignment="CENTER_LEFT" styleClass="welcome-stats">
                            <Label text="⚡ Réponse rapide" styleClass="welcome-stat-badge"/>
                            <Label text="🛡️ Modération sécurisée" styleClass="welcome-stat-badge"/>
                            <Label text="📊 Statistiques en temps réel" styleClass="welcome-stat-badge"/>
                        </HBox>
                    </VBox>

                    <!-- Statistics Section Title -->
                    <Label text="Statistiques" styleClass="simple-section-title"/>

                    <!-- Statistics Cards -->
                    <HBox spacing="18">
                        <VBox spacing="16.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                            <StackPane prefWidth="46.0" prefHeight="46.0" styleClass="stat-badge blue-badge">
                                <Label text="📋" styleClass="stat-emoji"/>
                            </StackPane>
                            <Label fx:id="totalPendingLabel" text="0" styleClass="stat-number"/>
                            <Label text="Posts en attente" styleClass="stat-text"/>
                        </VBox>

                        <VBox spacing="16.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                            <StackPane prefWidth="46.0" prefHeight="46.0" styleClass="stat-badge green-badge">
                                <Label text="✅" styleClass="stat-emoji"/>
                            </StackPane>
                            <Label fx:id="approvedTodayLabel" text="0" styleClass="stat-number"/>
                            <Label text="Approuvés aujourd'hui" styleClass="stat-text"/>
                        </VBox>

                        <VBox spacing="16.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                            <StackPane prefWidth="46.0" prefHeight="46.0" styleClass="stat-badge red-badge">
                                <Label text="❌" styleClass="stat-emoji"/>
                            </StackPane>
                            <Label fx:id="rejectedTodayLabel" text="0" styleClass="stat-number"/>
                            <Label text="Refusés aujourd'hui" styleClass="stat-text"/>
                        </VBox>
                    </HBox>

                    <!-- Search Section -->
                    <VBox spacing="16" styleClass="posts-list-card">
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <VBox spacing="4">
                                <Label text="Liste des posts à modérer" styleClass="posts-list-title"/>
                                <Label text="Consultez rapidement les publications en attente et choisissez une action."
                                       styleClass="posts-list-subtitle"/>
                            </VBox>

                            <Region HBox.hgrow="ALWAYS"/>

                            <Label text="En attente" styleClass="pending-chip"/>
                        </HBox>

                        <TextField fx:id="searchField"
                                   promptText="Rechercher par titre, contenu, catégorie ou auteur..."
                                   styleClass="moderation-search-field"/>

                        <VBox styleClass="modern-table-wrapper">
                            <TableView fx:id="pendingPostsTable"
                                       prefHeight="360"
                                       fixedCellSize="58"
                                       VBox.vgrow="ALWAYS"
                                       styleClass="modern-posts-table">

                                <columns>
                                    <TableColumn fx:id="titleCol" prefWidth="260.0" minWidth="190.0" text="TITRE"/>
                                    <TableColumn fx:id="categoryCol" prefWidth="145.0" minWidth="110.0" text="CATÉGORIE"/>
                                    <TableColumn fx:id="contentCol" prefWidth="380.0" minWidth="250.0" text="CONTENU"/>
                                    <TableColumn fx:id="dateCol" prefWidth="175.0" minWidth="145.0" text="DATE"/>
                                    <TableColumn fx:id="userCol" prefWidth="185.0" minWidth="140.0" text="AUTEUR"/>
                                    <TableColumn fx:id="actionsCol" prefWidth="220.0" minWidth="190.0" text="ACTIONS"/>
                                </columns>
                            </TableView>
                        </VBox>
                    </VBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>

