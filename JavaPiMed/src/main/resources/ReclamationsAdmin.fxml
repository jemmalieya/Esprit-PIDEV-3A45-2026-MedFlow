<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="rootPane"
            prefWidth="1500.0"
            prefHeight="880.0"
            styleClass="app-root"
            stylesheets="@CSS/admin-welcome.css,@CSS/reclamations-admin.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.ReclamationsAdminController">

    <left>
        <BorderPane prefWidth="320.0" styleClass="sidebar">

            <top>
                <VBox spacing="8">
                    <padding>
                        <Insets top="26" right="20" bottom="16" left="20"/>
                    </padding>

                    <Label text="MedFlow Admin" styleClass="brand-title"/>
                    <Label text="ESPACE ADMINISTRATION" styleClass="brand-subtitle"/>
                    <Separator styleClass="side-separator"/>
                </VBox>
            </top>

            <center>
                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" styleClass="sidebar-scroll">
                    <content>
                        <VBox spacing="10">
                            <padding>
                                <Insets top="4" right="18" bottom="16" left="18"/>
                            </padding>

                            <Button text="Accueil Admin" onAction="#openDashboard" styleClass="nav-button"/>

                            <TitledPane text="Utilisateurs" expanded="false" styleClass="sidebar-dropdown">
                                <content>
                                    <VBox spacing="6" styleClass="dropdown-content">
                                        <Button text="Patients" onAction="#openPatients" styleClass="sub-nav-button"/>
                                        <Button text="Tous les utilisateurs" onAction="#openUsers" styleClass="sub-nav-button"/>
                                        <Button text="Demandes de rôle" onAction="#openRoles" styleClass="sub-nav-button"/>
                                        <Button text="Comptes et permissions" onAction="#openUserRoles" styleClass="sub-nav-button"/>
                                    </VBox>
                                </content>
                            </TitledPane>

                            <TitledPane text="Produits" expanded="false" styleClass="sidebar-dropdown">
                                <content>
                                    <VBox spacing="6" styleClass="dropdown-content">
                                        <Button text="Liste des produits" onAction="#openProduits" styleClass="sub-nav-button"/>
                                        <Button text="Commandes" onAction="#openCommandes" styleClass="sub-nav-button"/>
                                        <Button text="Détection Épidémie" onAction="#openDetection" styleClass="sub-nav-button"/>
                                        <Button text="Stock et ruptures" onAction="#openStockRupture" styleClass="sub-nav-button"/>
                                        <Button text="Statistiques produits" onAction="#openStatsProduits" styleClass="sub-nav-button"/>
                                    </VBox>
                                </content>
                            </TitledPane>

                            <TitledPane text="Événements" expanded="false" styleClass="sidebar-dropdown">
                                <content>
                                    <VBox spacing="6" styleClass="dropdown-content">
                                        <Button text="Liste des événements" onAction="#openEvents" styleClass="sub-nav-button"/>
                                        <Button text="Participants demandes" onAction="#openEventParticipants" styleClass="sub-nav-button"/>
                                        <Button text="Ressources" onAction="#openRessources" styleClass="sub-nav-button"/>
                                        <Button text="Stats événements" onAction="#openStatsEvents" styleClass="sub-nav-button"/>
                                        <Button text="Stats ressources" onAction="#openStatsRessources" styleClass="sub-nav-button"/>
                                    </VBox>
                                </content>
                            </TitledPane>

                            <TitledPane text="Consultations" expanded="false" styleClass="sidebar-dropdown">
                                <content>
                                    <VBox spacing="6" styleClass="dropdown-content">
                                        <Button text="Consultations par Docteur" onAction="#openConsultations" styleClass="sub-nav-button"/>
                                        <Button text="Rendez-vous" onAction="#openRendezVous" styleClass="sub-nav-button"/>
                                        <Button text="Statistiques consultations" onAction="#openStatsConsultations" styleClass="sub-nav-button"/>
                                    </VBox>
                                </content>
                            </TitledPane>

                            <TitledPane text="Réclamations" expanded="true" styleClass="sidebar-dropdown">
                                <content>
                                    <VBox spacing="6" styleClass="dropdown-content">
                                        <Button text="Liste des réclamations"
                                                onAction="#openReclamations"
                                                styleClass="sub-nav-button"
                                                style="-fx-background-color: rgba(20, 184, 166, 0.25); -fx-text-fill: white;"/>
                                        <Button text="Statistiques réclamations" onAction="#openStatsReclamations" styleClass="sub-nav-button"/>
                                    </VBox>
                                </content>
                            </TitledPane>

                            <TitledPane text="Blog et Posts" expanded="false" styleClass="sidebar-dropdown">
                                <content>
                                    <VBox spacing="6" styleClass="dropdown-content">
                                        <Button text="Liste des posts" onAction="#openPosts" styleClass="sub-nav-button"/>
                                        <Button text="Posts en attente" onAction="#openPostsEnAttente" styleClass="sub-nav-button"/>
                                        <Button text="Statistiques blog" onAction="#openStatsBlog" styleClass="sub-nav-button"/>
                                    </VBox>
                                </content>
                            </TitledPane>

                            <Button text="Déconnexion" onAction="#logout" styleClass="logout-button"/>
                        </VBox>
                    </content>
                </ScrollPane>
            </center>

            <bottom>
                <VBox spacing="10">
                    <padding>
                        <Insets top="12" right="18" bottom="22" left="18"/>
                    </padding>

                    <Separator styleClass="side-separator"/>
                    <Button text="Retour Site" onAction="#goBackSite" styleClass="back-site-button"/>
                </VBox>
            </bottom>
        </BorderPane>
    </left>

    <top>
        <HBox alignment="CENTER_LEFT" spacing="18" styleClass="top-bar">
            <padding>
                <Insets top="18" right="28" bottom="18" left="28"/>
            </padding>

            <Button text="Menu" styleClass="menu-button"/>

            <VBox spacing="3">
                <Label text="Gestion des Réclamations" styleClass="page-title"/>
                <Label text="Suivez, filtrez et traitez les réclamations des patients" styleClass="page-subtitle"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <TextField promptText="Rechercher..." styleClass="search-field"/>
            <Button text="Notif" styleClass="icon-button"/>
            <Button text="Param" styleClass="icon-button"/>
            <Label text="A" styleClass="avatar-label"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" styleClass="content-scroll">
            <content>
                <VBox spacing="24" styleClass="reclamations-admin-content">
                    <padding>
                        <Insets top="34" right="38" bottom="45" left="38"/>
                    </padding>

                    <VBox spacing="16" styleClass="rec-hero-card">
                        <HBox spacing="16" alignment="CENTER_LEFT">
                            <StackPane prefWidth="68" prefHeight="68" styleClass="rec-hero-icon-box">
                                <Label text="💬" styleClass="rec-hero-icon"/>
                            </StackPane>

                            <VBox spacing="8" HBox.hgrow="ALWAYS">
                                <Label text="Centre de suivi des réclamations" styleClass="rec-hero-title"/>
                                <Label text="Consultez les réclamations, répondez aux patients et marquez les dossiers comme traités."
                                       wrapText="true"
                                       styleClass="rec-hero-subtitle"/>
                            </VBox>
                        </HBox>

                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <Label text="🛡️ Espace admin" styleClass="rec-hero-badge"/>
                            <Label text="⚡ Réponse rapide" styleClass="rec-hero-badge"/>
                            <Label text="📌 Priorité auto" styleClass="rec-hero-badge"/>
                            <Label text="📊 Suivi clair" styleClass="rec-hero-badge"/>
                        </HBox>
                    </VBox>

                    <HBox spacing="18">
                        <VBox spacing="12" styleClass="rec-stat-card blue-card" HBox.hgrow="ALWAYS">
                            <StackPane prefWidth="48" prefHeight="48" styleClass="rec-stat-icon blue-icon">
                                <Label text="📋" styleClass="rec-stat-emoji"/>
                            </StackPane>
                            <Label fx:id="totalReclamationsLabel" text="0" styleClass="rec-stat-number"/>
                            <Label text="Total réclamations" styleClass="rec-stat-text"/>
                        </VBox>

                        <VBox spacing="12" styleClass="rec-stat-card orange-card" HBox.hgrow="ALWAYS">
                            <StackPane prefWidth="48" prefHeight="48" styleClass="rec-stat-icon orange-icon">
                                <Label text="⏳" styleClass="rec-stat-emoji"/>
                            </StackPane>
                            <Label fx:id="enAttenteLabel" text="0" styleClass="rec-stat-number"/>
                            <Label text="En attente" styleClass="rec-stat-text"/>
                        </VBox>

                        <VBox spacing="12" styleClass="rec-stat-card green-card" HBox.hgrow="ALWAYS">
                            <StackPane prefWidth="48" prefHeight="48" styleClass="rec-stat-icon green-icon">
                                <Label text="✅" styleClass="rec-stat-emoji"/>
                            </StackPane>
                            <Label fx:id="traiteesLabel" text="0" styleClass="rec-stat-number"/>
                            <Label text="Traitées" styleClass="rec-stat-text"/>
                        </VBox>

                        <VBox spacing="12" styleClass="rec-stat-card red-card" HBox.hgrow="ALWAYS">
                            <StackPane prefWidth="48" prefHeight="48" styleClass="rec-stat-icon red-icon">
                                <Label text="🚨" styleClass="rec-stat-emoji"/>
                            </StackPane>
                            <Label fx:id="critiquesLabel" text="0" styleClass="rec-stat-number"/>
                            <Label text="Priorité élevée" styleClass="rec-stat-text"/>
                        </VBox>
                    </HBox>

                    <VBox spacing="18" styleClass="reclamations-table-card">
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <VBox spacing="4">
                                <Label text="Liste des réclamations" styleClass="rec-section-title"/>
                                <Label text="Visualisez les demandes, priorités, statuts et actions disponibles."
                                       styleClass="rec-section-subtitle"/>
                            </VBox>

                            <Region HBox.hgrow="ALWAYS"/>

                            <Button text="Actualiser" onAction="#refreshData" styleClass="secondary-action-btn"/>
                        </HBox>

                        <HBox spacing="14" alignment="CENTER_LEFT">
                            <TextField fx:id="searchField"
                                       promptText="Rechercher par référence, type, statut, priorité, description..."
                                       HBox.hgrow="ALWAYS"
                                       styleClass="rec-filter-field"/>

                            <ComboBox fx:id="statusFilter"
                                      promptText="Statut"
                                      prefWidth="170"
                                      styleClass="rec-filter-combo"/>

                            <ComboBox fx:id="priorityFilter"
                                      promptText="Priorité"
                                      prefWidth="170"
                                      styleClass="rec-filter-combo"/>
                        </HBox>

                        <VBox styleClass="rec-table-wrapper">
                            <TableView fx:id="reclamationTable"
                                       prefHeight="430"
                                       fixedCellSize="60"
                                       VBox.vgrow="ALWAYS"
                                       styleClass="rec-table">

                                <columns>
                                    <TableColumn fx:id="referenceCol" text="RÉFÉRENCE" prefWidth="170"/>
                                    <TableColumn fx:id="typeCol" text="TYPE" prefWidth="170"/>
                                    <TableColumn fx:id="statutCol" text="STATUT" prefWidth="160"/>
                                    <TableColumn fx:id="prioriteCol" text="PRIORITÉ" prefWidth="160"/>
                                    <TableColumn fx:id="descriptionCol" text="DESCRIPTION" prefWidth="520"/>
                                    <TableColumn fx:id="dateCol" text="DATE" prefWidth="220"/>
                                </columns>
                            </TableView>
                        </VBox>

                        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="rec-footer-note">
                            <Label text="ℹ" styleClass="footer-note-icon"/>
                            <Label text="Astuce : une réclamation avec priorité élevée doit être traitée rapidement."
                                   wrapText="true"
                                   styleClass="rec-footer-text"/>
                        </HBox>
                    </VBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>