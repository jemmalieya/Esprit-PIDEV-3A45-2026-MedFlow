<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.RessourceController"
            prefWidth="1650.0"
            prefHeight="960.0"
            styleClass="root-pane"
            stylesheets="@CSS/evenement-dashboard.css">

    <left>
        <VBox prefWidth="250.0" minWidth="250.0" maxWidth="250.0" styleClass="sidebar">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="14.0" styleClass="logo-box">
                    <children>
                        <StackPane prefWidth="40.0" prefHeight="40.0">
                            <children>
                                <Label text="+" styleClass="logo-plus"/>
                                <Label text="&#10084;" styleClass="logo-heart"/>
                            </children>
                        </StackPane>
                        <Label text="MEDFLOW" styleClass="logo-text"/>
                    </children>
                </HBox>

                <Region prefHeight="1.0" maxHeight="1.0" styleClass="sidebar-separator"/>

                <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="sidebar-item">
                    <children>
                        <Label text="Dashboard" styleClass="sidebar-item-text"/>
                    </children>
                </HBox>

                <Label text="GESTIONS" styleClass="sidebar-section-title"/>

                <Button text=""
                        onAction="#toggleSubmenu"
                        alignment="CENTER_LEFT"
                        maxWidth="Infinity"
                        prefWidth="220.0"
                        contentDisplay="GRAPHIC_ONLY"
                        styleClass="sidebar-item, sidebar-btn">
                    <graphic>
                        <HBox alignment="CENTER_LEFT" spacing="10.0" maxWidth="Infinity">
                            <children>
                                <Label text="" styleClass="sidebar-item-icon"/>
                                <Label text="Ressources" styleClass="sidebar-item-text"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label fx:id="ressourceArrow" text="v" styleClass="sidebar-arrow"/>
                            </children>
                        </HBox>
                    </graphic>
                </Button>

                <VBox fx:id="submenuVBox"
                      spacing="18.0"
                      styleClass="submenu-card"
                      managed="false"
                      visible="false"
                      maxWidth="220.0">
                    <children>
                        <Label text="GESTION DES RESSOURCES :" styleClass="submenu-title"/>
                        <Button text="Voir toutes les ressources" onAction="#onVoirTousRessources" maxWidth="Infinity" alignment="CENTER_LEFT" styleClass="submenu-link"/>
                        <Button text="Nouvelle ressource" onAction="#onNewRessource" maxWidth="Infinity" alignment="CENTER_LEFT" styleClass="submenu-link"/>
                        <Button text="Gestion evenements" onAction="#onGestionEvenements" maxWidth="Infinity" alignment="CENTER_LEFT" styleClass="submenu-link"/>
                    </children>
                </VBox>

                <Region VBox.vgrow="ALWAYS"/>

                <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="sidebar-item">
                    <children>
                        <Label text="Quitter" styleClass="sidebar-item-text"/>
                    </children>
                </HBox>
            </children>
            <padding>
                <Insets top="24.0" right="18.0" bottom="24.0" left="18.0"/>
            </padding>
        </VBox>
    </left>

    <center>
        <VBox spacing="22.0" styleClass="main-area">
            <padding>
                <Insets top="18.0" right="22.0" bottom="22.0" left="22.0"/>
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="14.0" styleClass="top-search-box">
                <children>
                    <TextField fx:id="searchField" promptText="Rechercher une ressource..." HBox.hgrow="ALWAYS" styleClass="top-search-input"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="" styleClass="notif-icon"/>
                </children>
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="hero-card">
                <children>
                    <StackPane minWidth="88.0" minHeight="88.0" prefWidth="88.0" prefHeight="88.0" styleClass="hero-icon-box">
                        <children>
                            <Label text="&#128230;" styleClass="hero-icon"/>
                        </children>
                    </StackPane>
                    <VBox spacing="10.0">
                        <children>
                            <Label text="Gestion des Ressources" styleClass="hero-title"/>
                            <HBox spacing="14.0" alignment="CENTER_LEFT">
                                <children>
                                    <Label fx:id="inventoryCountLabel" text="0 ressource(s) dans votre espace" styleClass="hero-subtitle"/>
                                    <Label text="Admin" styleClass="admin-badge"/>
                                </children>
                            </HBox>
                        </children>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <HBox spacing="16.0" alignment="CENTER_RIGHT">
                        <children>
                            <Button text="Nouvelle ressource" onAction="#onNewRessource" styleClass="yellow-btn"/>
                            <Button text="Gestion evenements" onAction="#onGestionEvenements" styleClass="white-btn"/>
                        </children>
                    </HBox>
                </children>
                <padding>
                    <Insets top="30.0" right="30.0" bottom="30.0" left="30.0"/>
                </padding>
            </HBox>

            <VBox spacing="16.0" styleClass="list-header-card">
                <children>
                    <HBox alignment="CENTER_LEFT" spacing="18.0">
                        <children>
                            <HBox spacing="12.0" alignment="CENTER_LEFT">
                                <children>
                                    <Label text="&#9776;" styleClass="list-icon"/>
                                    <Label text="Liste des Ressources" styleClass="list-title"/>
                                </children>
                            </HBox>
                            <Region HBox.hgrow="ALWAYS"/>
                            <HBox spacing="12.0" alignment="CENTER_RIGHT">
                                <children>
                                    <Label text="Filtres" styleClass="pill-label"/>
                                    <ComboBox fx:id="sortCombo" styleClass="sort-combo"/>
                                </children>
                            </HBox>
                        </children>
                    </HBox>
                </children>
                <padding>
                    <Insets top="22.0" right="24.0" bottom="22.0" left="24.0"/>
                </padding>
            </VBox>

            <HBox spacing="24.0">
                <children>
                    <VBox spacing="16.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                        <children>
                            <StackPane prefWidth="46.0" prefHeight="46.0" styleClass="stat-badge blue-badge">
                                <children><Label text="&#128230;" styleClass="stat-emoji"/></children>
                            </StackPane>
                            <Label fx:id="totalResourcesLabel" text="0" styleClass="stat-number"/>
                            <Label text="Total Ressources" styleClass="stat-text"/>
                        </children>
                    </VBox>
                    <VBox spacing="16.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                        <children>
                            <StackPane prefWidth="46.0" prefHeight="46.0" styleClass="stat-badge green-badge">
                                <children><Label text="&#128196;" styleClass="stat-emoji"/></children>
                            </StackPane>
                            <Label fx:id="fileResourcesLabel" text="0" styleClass="stat-number"/>
                            <Label text="Type Fichier" styleClass="stat-text"/>
                        </children>
                    </VBox>
                    <VBox spacing="16.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                        <children>
                            <StackPane prefWidth="46.0" prefHeight="46.0" styleClass="stat-badge orange-badge">
                                <children><Label text="&#128279;" styleClass="stat-emoji"/></children>
                            </StackPane>
                            <Label fx:id="linkResourcesLabel" text="0" styleClass="stat-number"/>
                            <Label text="Liens Externes" styleClass="stat-text"/>
                        </children>
                    </VBox>
                    <VBox spacing="16.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                        <children>
                            <StackPane prefWidth="46.0" prefHeight="46.0" styleClass="stat-badge red-badge">
                                <children><Label text="&#129520;" styleClass="stat-emoji"/></children>
                            </StackPane>
                            <Label fx:id="stockResourcesLabel" text="0" styleClass="stat-number"/>
                            <Label text="Stock / Materiel" styleClass="stat-text"/>
                        </children>
                    </VBox>
                    <VBox spacing="16.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                        <children>
                            <StackPane prefWidth="46.0" prefHeight="46.0" styleClass="stat-badge blue-badge">
                                <children><Label text="&#128336;" styleClass="stat-emoji"/></children>
                            </StackPane>
                            <Label fx:id="historiqueResourcesLabel" text="0" styleClass="stat-number"/>
                            <Label text="Historique" styleClass="stat-text"/>
                        </children>
                    </VBox>
                </children>
            </HBox>

            <VBox styleClass="table-wrapper" VBox.vgrow="ALWAYS">
                <children>
                    <TableView fx:id="ressourceTable" VBox.vgrow="ALWAYS" prefHeight="620" styleClass="events-table">
                        <columns>
                            <TableColumn fx:id="eventCol" prefWidth="260.0" text="EVENEMENT"/>
                            <TableColumn fx:id="nomCol" prefWidth="190.0" text="NOM"/>
                            <TableColumn fx:id="categorieCol" prefWidth="180.0" text="CATEGORIE"/>
                            <TableColumn fx:id="typeCol" prefWidth="150.0" text="TYPE"/>
                            <TableColumn fx:id="quantiteCol" prefWidth="120.0" text="QUANTITE"/>
                            <TableColumn fx:id="fournisseurCol" prefWidth="210.0" text="FOURNISSEUR"/>
                            <TableColumn fx:id="notesCol" prefWidth="360.0" text="NOTES"/>
                            <TableColumn fx:id="actionsCol" prefWidth="320.0" text="ACTIONS"/>
                        </columns>
                    </TableView>
                </children>
            </VBox>
        </VBox>
    </center>
</BorderPane>
